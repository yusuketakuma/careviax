{
  "name": "careviax",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.14.1"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e:local": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT=1 AUTH_SECRET=careviax-local-auth-secret NEXTAUTH_SECRET=careviax-local-auth-secret NEXTAUTH_URL=http://localhost:3012 NEXT_PUBLIC_DISABLE_NOTIFICATION_STREAM=1 NEXT_FONT_GOOGLE_MOCKED_RESPONSES=$PWD/tools/tests/helpers/next-font-google-mocked-responses.cjs next dev --webpack --port 3012",
    "build:e2e:local": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT=1 AUTH_SECRET=careviax-local-auth-secret NEXTAUTH_SECRET=careviax-local-auth-secret NEXTAUTH_URL=http://localhost:3012 NEXT_PUBLIC_DISABLE_NOTIFICATION_STREAM=1 NEXT_FONT_GOOGLE_MOCKED_RESPONSES=$PWD/tools/tests/helpers/next-font-google-mocked-responses.cjs next build --webpack",
    "build": "next build --webpack",
    "start:e2e:local": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT=1 AUTH_SECRET=careviax-local-auth-secret NEXTAUTH_SECRET=careviax-local-auth-secret NEXTAUTH_URL=http://localhost:3012 NEXT_PUBLIC_DISABLE_NOTIFICATION_STREAM=1 NEXT_FONT_GOOGLE_MOCKED_RESPONSES=$PWD/tools/tests/helpers/next-font-google-mocked-responses.cjs next start --port 3012",
    "start": "next start",
    "lint": "eslint .",
    "postinstall": "prisma generate --schema=prisma/schema/ && node tools/scripts/link-prisma-client.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:local": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT_REUSE_SERVER=1 PLAYWRIGHT_BASE_URL=http://localhost:3012 playwright test --config playwright.local.config.ts",
    "test:e2e:local:list": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT_BASE_URL=http://localhost:3012 playwright test --config playwright.local.config.ts --list",
    "test:e2e:list": "playwright test --list",
    "test:e2e:audit": "playwright test --config playwright.audit.config.ts",
    "test:e2e:audit:list": "playwright test --config playwright.audit.config.ts --list",
    "test:e2e:harness:doctor": "sh tools/browser-harness/run.sh --doctor",
    "test:e2e:harness:patient-detail": "sh tools/browser-harness/run.sh < tools/browser-harness/patient-detail-smoke.py",
    "perf:smoke": "tsx tools/scripts/perf-smoke.ts",
    "pilot:readiness": "tsx tools/scripts/pilot-readiness-report.ts",
    "pilot:org-audit": "tsx tools/scripts/pilot-org-audit.ts",
    "pilot:dossier": "tsx tools/scripts/pilot-dossier.ts",
    "uat:summary": "tsx tools/scripts/uat-feedback-summary.ts",
    "backup:drill:check": "tsx tools/scripts/backup-recovery-check.ts",
    "pmda:onboarding:check": "tsx tools/scripts/pmda-onboarding-check.ts",
    "db:check-care-report-duplicates": "tsx tools/scripts/check-care-report-duplicates.ts",
    "db:external-access-case-boundary-audit": "tsx tools/scripts/external-access-case-boundary-audit.ts",
    "db:e2e:check-care-report-duplicates": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public tsx tools/scripts/check-care-report-duplicates.ts",
    "medical-ui:e2e:preflight": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public tsx tools/scripts/medical-ui-e2e-preflight.ts",
    "medical-ui:e2e:targeted": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public PLAYWRIGHT_REUSE_SERVER=1 PLAYWRIGHT_BASE_URL=http://localhost:3012 playwright test --config playwright.local.config.ts tools/tests/ui-audit-extensions.spec.ts tools/tests/ui-mobile-layout.spec.ts tools/tests/ui-schedule-visit-report.spec.ts tools/tests/e2e-prescription-dispensing-flow.spec.ts tools/tests/ui-detail-layout.spec.ts",
    "medical-ui:e2e:gate": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public pnpm medical-ui:e2e:preflight && pnpm db:e2e:check-care-report-duplicates && pnpm medical-ui:e2e:targeted",
    "medical-ui:e2e:gate:prod": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public tsx tools/scripts/run-medical-ui-e2e-gate.ts",
    "db:e2e:push": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public prisma db push --schema=prisma/schema/",
    "db:e2e:seed": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public prisma db seed",
    "db:e2e:prepare": "DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public pnpm db:e2e:push && DATABASE_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public DIRECT_URL=postgresql://careviax:careviax@localhost:5433/careviax_e2e?schema=public pnpm db:e2e:seed",
    "db:migrate": "prisma migrate dev --schema=prisma/schema/",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate --schema=prisma/schema/ && node tools/scripts/link-prisma-client.mjs",
    "format": "prettier --write ."
  },
