    "@aws-sdk/client-dynamodb": "^3.1065.0",
    "@aws-sdk/client-rds": "^3.1065.0",
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/client-secrets-manager": "^3.1065.0",
    "@aws-sdk/client-ses": "^3.1065.0",
    "@aws-sdk/client-sns": "^3.1065.0",
