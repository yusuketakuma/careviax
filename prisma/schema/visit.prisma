enum VisitType {
  initial
  regular
  temporary
  revisit
  delivery_only
  emergency
  physician_co_visit
}

enum ScheduleStatus {
  planned
  in_preparation
  ready
  departed
  in_progress
  completed
  cancelled
  postponed
  rescheduled
  no_show
}

enum VisitPriority {
  normal
  urgent
  emergency
}

enum VisitProposalStatus {
  proposed
  patient_contact_pending
  confirmed
  rejected
  superseded
  expired
  reschedule_pending
}

enum PatientContactStatus {
  pending
  attempted
  confirmed
  declined
  change_requested
  unreachable
}

enum VisitAssignmentMode {
  primary
  fallback
}

enum VisitOutcome {
  completed
  revisit_needed
  postponed
  cancelled
  delivery_only
  completed_with_issue
}

enum VisitVehicleTravelMode {
  DRIVE
  BICYCLE
  WALK
  TWO_WHEELER
}

enum VisitScheduleOverrideStatus {
  pending
  completed
  cancelled
}

model VisitVehicleResource {
  id                         String                 @id @default(cuid())
  org_id                     String
  display_id                 String?
  org                        Organization           @relation(fields: [org_id], references: [id])
  site_id                    String
  site                       PharmacySite           @relation(fields: [site_id, org_id], references: [id, org_id])
  label                      String
  vehicle_code               String?
  travel_mode                VisitVehicleTravelMode @default(DRIVE)
  max_stops                  Int                    @default(8)
  max_route_duration_minutes Int?
  available                  Boolean                @default(true)
  next_inspection_date       DateTime?              @db.Date // 車検/点検期限（notes 正規表現依存を解消する専用カラム）
  notes                      String?
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt

  visit_schedules          VisitSchedule[]         @relation("VisitScheduleVehicleResource")
  visit_schedule_proposals VisitScheduleProposal[] @relation("VisitScheduleProposalVehicleResource")

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@unique([org_id, vehicle_code])
  @@index([org_id])
  @@index([org_id, site_id, available])
  @@index([site_id])
}

model VisitSchedule {
  id                            String                @id @default(cuid())
  org_id                        String
  display_id                    String?
  cycle_id                      String?
  cycle                         MedicationCycle?      @relation(fields: [cycle_id], references: [id])
  case_id                       String
  case_                         CareCase              @relation(fields: [case_id], references: [id])
  site_id                       String?
  site                          PharmacySite?         @relation(fields: [site_id], references: [id])
  visit_type                    VisitType
  priority                      VisitPriority         @default(normal)
  schedule_status               ScheduleStatus        @default(planned)
  scheduled_date                DateTime              @db.Date
  time_window_start             DateTime?             @db.Time()
  time_window_end               DateTime?             @db.Time()
  pharmacist_id                 String // User ID
  assignment_mode               VisitAssignmentMode   @default(primary)
  escalation_reason             String?
  route_order                   Int?
  vehicle_resource_id           String?
  vehicle_resource              VisitVehicleResource? @relation("VisitScheduleVehicleResource", fields: [vehicle_resource_id, org_id], references: [id, org_id])
  carry_items                   Json? // 持参薬情報
  carry_items_status            String? // ready/partial/blocked
  pre_visit_checklist_completed Boolean               @default(false)
  recurrence_rule               String? // RRULE
  recurrence_parent_id          String? // 繰返しの親スケジュールID
  facility_batch_id             String?
  facility_batch                FacilityVisitBatch?   @relation(fields: [facility_batch_id], references: [id])
  facility_unit_id              String?
  facility_unit                 FacilityUnit?         @relation(fields: [facility_unit_id], references: [id])
  time_constraint_start         DateTime?             @db.Time()
  time_constraint_end           DateTime?             @db.Time()
  medication_start_date         DateTime?             @db.Date
  medication_end_date           DateTime?             @db.Date
  visit_deadline_date           DateTime?             @db.Date
  confirmed_at                  DateTime?
  confirmed_by                  String?
  version                       Int                   @default(1)
  created_at                    DateTime              @default(now())
  updated_at                    DateTime              @updatedAt

  visit_record          VisitRecord?
  handoff_extraction    VisitHandoffExtraction?
  preparation           VisitPreparation?
  proposal_finalization VisitScheduleProposal?    @relation("ProposalFinalizedSchedule")
  reschedule_proposals  VisitScheduleProposal[]   @relation("ProposalRescheduleSource")
  contact_logs          VisitScheduleContactLog[]
  override_request      VisitScheduleOverride?    @relation("OverrideSourceSchedule")
  applied_override      VisitScheduleOverride?    @relation("OverrideReplacementSchedule")

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@index([org_id])
  @@index([scheduled_date])
  @@index([pharmacist_id])
  @@index([schedule_status])
  @@index([case_id])
  @@index([site_id, scheduled_date])
  @@index([facility_unit_id])
  @@index([org_id, scheduled_date, schedule_status])
  @@index([org_id, pharmacist_id, scheduled_date])
  @@index([org_id, pharmacist_id, scheduled_date, route_order], map: "VisitSchedule_route_cell_order_idx")
  @@index([org_id, vehicle_resource_id])
}

model FacilityVisitBatch {
  id                  String        @id @default(cuid())
  org_id              String
  display_id          String?
  facility_id         String // 施設ID
  facility_unit_id    String? // ユニットID（ユニット単位グルーピング時）
  facility_unit       FacilityUnit? @relation(fields: [facility_unit_id], references: [id])
  scheduled_date      DateTime      @db.Date
  pharmacist_id       String
  patient_ids         Json // String[]
  estimated_duration  Int? // 分
  route_from_pharmacy Json? // ルート情報
  notes               String? // 施設共通注意事項
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  visit_schedules VisitSchedule[]

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([scheduled_date])
  @@index([facility_unit_id])
}

model VisitRecord {
  id                         String        @id @default(cuid())
  org_id                     String
  display_id                 String?
  schedule_id                String        @unique
  schedule                   VisitSchedule @relation(fields: [schedule_id], references: [id])
  patient_id                 String
  pharmacist_id              String
  visit_date                 DateTime
  outcome_status             VisitOutcome
  soap_subjective            String? // S
  soap_objective             String? // O
  soap_assessment            String? // A
  soap_plan                  String? // P
  receipt_person_name        String? // 受領者名
  receipt_person_relation    String? // 続柄
  receipt_at                 DateTime?
  next_visit_suggestion_date DateTime?     @db.Date
  cancellation_reason        String?
  postpone_reason            String?
  revisit_reason             String?
  structured_soap            Json? // StructuredSoap (構造化SOAP、薬学的評価シート7項目含む)
  visit_geo_log              Json? // optional geolocation log for visit start/end
  attachments                Json? // S3 URLs
  patient_state_snapshot     Json? // 訪問時点の患者詳細スナップショット(過去訪問の不変参照 / 前回訪問差分の基準点)
  version                    Int           @default(1)
  created_at                 DateTime      @default(now())
  updated_at                 DateTime      @updatedAt

  handoff_extraction    VisitHandoffExtraction?
  partner_visit_records PartnerVisitRecord[]    @relation("PartnerVisitRecordSourceVisit")

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([visit_date])
  @@index([schedule_id])
}

model VisitHandoffExtraction {
  id                             String        @id @default(cuid())
  org_id                         String
  display_id                     String?
  visit_record_id                String        @unique
  visit_record                   VisitRecord   @relation(fields: [visit_record_id], references: [id], onDelete: Cascade)
  schedule_id                    String        @unique
  schedule                       VisitSchedule @relation(fields: [schedule_id], references: [id], onDelete: Cascade)
  source_visit_record_version    Int
  source_visit_record_updated_at DateTime
  status                         String
  retry_count                    Int           @default(0)
  last_attempted_at              DateTime?
  last_succeeded_at              DateTime?
  last_failed_at                 DateTime?
  error_message                  String?
  retryable                      Boolean       @default(false)
  created_at                     DateTime      @default(now())
  updated_at                     DateTime      @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([status])
}

model VisitPreparation {
  id                          String        @id @default(cuid())
  org_id                      String
  display_id                  String?
  schedule_id                 String        @unique
  schedule                    VisitSchedule @relation(fields: [schedule_id], references: [id])
  checklist                   Json
  medication_changes_reviewed Boolean       @default(false)
  carry_items_confirmed       Boolean       @default(false)
  previous_issues_reviewed    Boolean       @default(false)
  route_confirmed             Boolean       @default(false)
  route_plan_snapshot         Json?
  offline_synced              Boolean       @default(false)
  prepared_by                 String // User ID
  prepared_at                 DateTime?
  created_at                  DateTime      @default(now())
  updated_at                  DateTime      @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([schedule_id])
}

model VisitScheduleProposal {
  id                            String                      @id @default(cuid())
  org_id                        String
  display_id                    String?
  proposal_batch_id             String?
  proposal_batch                VisitScheduleProposalBatch? @relation(fields: [proposal_batch_id], references: [id])
  cycle_id                      String?
  cycle                         MedicationCycle?            @relation(fields: [cycle_id], references: [id])
  case_id                       String
  case_                         CareCase                    @relation(fields: [case_id], references: [id])
  site_id                       String?
  site                          PharmacySite?               @relation(fields: [site_id], references: [id])
  visit_type                    VisitType
  priority                      VisitPriority               @default(normal)
  proposal_status               VisitProposalStatus         @default(proposed)
  patient_contact_status        PatientContactStatus        @default(pending)
  proposed_date                 DateTime                    @db.Date
  time_window_start             DateTime?                   @db.Time()
  time_window_end               DateTime?                   @db.Time()
  proposed_pharmacist_id        String
  assignment_mode               VisitAssignmentMode         @default(primary)
  route_order                   Int?
  route_distance_score          Float?
  vehicle_resource_id           String?
  vehicle_resource              VisitVehicleResource?       @relation("VisitScheduleProposalVehicleResource", fields: [vehicle_resource_id, org_id], references: [id, org_id])
  medication_end_date           DateTime?                   @db.Date
  visit_deadline_date           DateTime?                   @db.Date
  proposal_reason               String?
  reject_reason                 String?
  suggested_recurrence_rule     String?
  escalation_reason             String?
  approved_by                   String?
  approved_at                   DateTime?
  patient_contacted_at          DateTime?
  confirmed_by                  String?
  confirmed_at                  DateTime?
  finalized_schedule_id         String?
  finalized_schedule            VisitSchedule?              @relation("ProposalFinalizedSchedule", fields: [finalized_schedule_id, org_id], references: [id, org_id], onDelete: Restrict, onUpdate: Cascade)
  reschedule_source_schedule_id String?
  reschedule_source_schedule    VisitSchedule?              @relation("ProposalRescheduleSource", fields: [reschedule_source_schedule_id], references: [id])
  reproposal_source_proposal_id String?
  reproposal_source_proposal    VisitScheduleProposal?      @relation("ProposalReproposalSource", fields: [reproposal_source_proposal_id, org_id, case_id], references: [id, org_id, case_id], onDelete: Restrict, onUpdate: Cascade)
  reproposal_children           VisitScheduleProposal[]     @relation("ProposalReproposalSource")
  contact_logs                  VisitScheduleContactLog[]
  created_at                    DateTime                    @default(now())
  updated_at                    DateTime                    @updatedAt

  @@unique([org_id, display_id])
  @@unique([id, org_id, case_id], map: "VisitScheduleProposal_id_org_id_case_id_key")
  @@unique([finalized_schedule_id, org_id])
  @@index([org_id, proposal_status])
  @@index([case_id, proposed_date])
  @@index([site_id, proposed_date])
  @@index([org_id, vehicle_resource_id])
  @@index([proposal_batch_id])
  @@index([org_id, reproposal_source_proposal_id], map: "VisitScheduleProposal_org_id_reproposal_source_proposal_id_idx")
  @@index([org_id, proposed_pharmacist_id, proposed_date, route_order], map: "VisitScheduleProposal_route_cell_order_idx")
}

model VisitScheduleProposalBatch {
  id                  String       @id @default(cuid())
  org_id              String
  display_id          String?
  org                 Organization @relation(fields: [org_id], references: [id])
  case_id             String
  idempotency_key     String
  request_fingerprint String
  created_by          String
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  proposals VisitScheduleProposal[]

  @@unique([org_id, display_id])
  @@unique([org_id, idempotency_key])
  @@index([org_id, case_id])
}

model VisitScheduleContactLog {
  id                  String                @id @default(cuid())
  org_id              String
  display_id          String?
  proposal_id         String
  proposal            VisitScheduleProposal @relation(fields: [proposal_id], references: [id])
  schedule_id         String?
  schedule            VisitSchedule?        @relation(fields: [schedule_id], references: [id])
  patient_id          String
  case_id             String
  outcome             PatientContactStatus
  contact_method      String?
  contact_name        String?
  contact_phone       String?
  note                String?
  callback_due_at     DateTime?
  idempotency_key     String?
  request_fingerprint String?
  called_at           DateTime              @default(now())
  called_by           String
  created_at          DateTime              @default(now())
  updated_at          DateTime              @updatedAt

  @@unique([org_id, display_id])
  @@unique([org_id, idempotency_key])
  @@index([org_id, proposal_id])
  @@index([org_id, schedule_id])
  @@index([org_id, patient_id])
  @@index([called_at])
}

model VisitScheduleOverride {
  id                      String                      @id @default(cuid())
  org_id                  String
  display_id              String?
  source_schedule_id      String                      @unique
  source_schedule         VisitSchedule               @relation("OverrideSourceSchedule", fields: [source_schedule_id], references: [id])
  replacement_schedule_id String?                     @unique
  replacement_schedule    VisitSchedule?              @relation("OverrideReplacementSchedule", fields: [replacement_schedule_id], references: [id])
  status                  VisitScheduleOverrideStatus @default(pending)
  reason                  String
  requested_by            String
  approved_by             String?
  requested_at            DateTime                    @default(now())
  approved_at             DateTime?
  before_snapshot         Json
  impact_summary          Json?
  after_snapshot          Json?
  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id, status])
}
