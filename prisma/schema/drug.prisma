enum InteractionSeverity {
  contraindicated
  caution
  minor
}

enum InteractionSource {
  pmda_xml
  kegg
  manual
}

enum AlertType {
  interaction
  duplicate
  allergy_cross
  renal_dose
  pim_elderly
  high_risk
  narcotic
  max_days
}

enum AlertSeverity {
  critical
  warning
  info
}

enum DocumentSourceFormat {
  xml
  sgml
  pdf
}

enum ImportSource {
  ssk
  pmda
  mhlw_price
  mhlw_generic
  hot
  manual_clinical
}

enum ImportStatus {
  pending
  running
  completed
  failed
}

// グローバルマスタ（org_id なし）
model DrugMaster {
  id                       String    @id @default(cuid())
  yj_code                  String    @unique // YJコード 12桁
  receipt_code             String? // レセ電コード 9桁
  hot_code                 String? // HOTコード 13桁
  jan_code                 String?
  drug_name                String
  drug_name_kana           String?
  generic_name             String?
  drug_price               Decimal?  @db.Decimal(12, 2)
  unit                     String?
  dosage_form              String?
  therapeutic_category     String? // 薬効分類 4桁
  manufacturer             String?
  is_generic               Boolean   @default(false)
  is_narcotic              Boolean   @default(false)
  is_psychotropic          Boolean   @default(false)
  is_high_risk             Boolean   @default(false)
  is_lasa_risk             Boolean   @default(false)
  tall_man_name            String?
  lasa_group_key           String?
  max_administration_days  Int?
  transitional_expiry_date DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  package_inserts   DrugPackageInsert[]
  interactions_as_a DrugInteraction[]   @relation("DrugA")
  interactions_as_b DrugInteraction[]   @relation("DrugB")
  drug_stocks       PharmacyDrugStock[]
  preferred_stocks  PharmacyDrugStock[] @relation("PreferredGeneric")

  @@index([yj_code])
  @@index([receipt_code])
  @@index([hot_code])
  @@index([jan_code])
  @@index([drug_name_kana])
  @@index([generic_name])
  @@index([therapeutic_category])
  @@index([is_high_risk])
  @@index([is_lasa_risk])
  @@index([is_narcotic])
  @@index([is_psychotropic])
  @@index([transitional_expiry_date])
  @@index([lasa_group_key])
}

// グローバルマスタ（org_id なし）
model DrugPackageInsert {
  id                      String                @id @default(cuid())
  drug_master_id          String
  drug_master             DrugMaster            @relation(fields: [drug_master_id], references: [id])
  contraindications       Json?
  interactions            Json?
  adverse_effects         Json?
  dosage_adjustment_renal Json?
  precautions_elderly     Json?
  document_version        String?
  revised_at              DateTime?
  source_format           DocumentSourceFormat?
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  @@index([drug_master_id])
}

// グローバルマスタ（org_id なし）
model DrugInteraction {
  id              String              @id @default(cuid())
  drug_a_id       String
  drug_a          DrugMaster          @relation("DrugA", fields: [drug_a_id], references: [id])
  drug_b_id       String
  drug_b          DrugMaster          @relation("DrugB", fields: [drug_b_id], references: [id])
  severity        InteractionSeverity
  mechanism       String?
  clinical_effect String?
  source          InteractionSource
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  @@unique([drug_a_id, drug_b_id, source])
  @@index([drug_a_id])
  @@index([drug_b_id])
}

// グローバルマスタ（org_id なし）
model DrugAlertRule {
  id         String        @id @default(cuid())
  alert_type AlertType
  condition  Json
  severity   AlertSeverity
  message    String
  is_active  Boolean       @default(true)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([alert_type])
}

// テナント別
model PharmacyDrugStock {
  id                    String       @id @default(cuid())
  org_id                String
  site_id               String
  site                  PharmacySite @relation(fields: [site_id], references: [id])
  drug_master_id        String
  drug_master           DrugMaster   @relation(fields: [drug_master_id], references: [id])
  is_stocked            Boolean      @default(true)
  stock_qty             Int?
  reorder_point         Int?
  last_dispensed_at     DateTime?
  preferred_generic_id  String?
  preferred_generic     DrugMaster?  @relation("PreferredGeneric", fields: [preferred_generic_id], references: [id])
  adoption_source       String?
  adoption_note         String?
  last_reviewed_at      DateTime?
  reviewed_by_id        String?
  follow_up_status      String?
  follow_up_reason      String?
  follow_up_due_date    DateTime?
  follow_up_resolved_at DateTime?
  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt

  @@unique([site_id, drug_master_id])
  @@index([org_id])
  @@index([site_id])
  @@index([org_id, site_id, is_stocked])
  @@index([org_id, site_id, is_stocked, last_reviewed_at], map: "PharmacyDrugStock_impact_review_due_idx")
  @@index([org_id, site_id, is_stocked, reorder_point], map: "PharmacyDrugStock_impact_reorder_idx")
  @@index([org_id, site_id, is_stocked, follow_up_status], map: "PharmacyDrugStock_impact_follow_up_idx")
  @@index([last_reviewed_at])
  @@index([follow_up_status])
}

model FormularyChangeRequest {
  id                String    @id @default(cuid())
  org_id            String
  site_id           String
  drug_master_id    String
  requested_by_id   String
  decided_by_id     String?
  status            String    @default("pending")
  action_type       String
  requested_payload Json
  current_snapshot  Json?
  reason            String?
  decision_note     String?
  decided_at        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([org_id, site_id, status])
  @@index([org_id, drug_master_id, status])
  @@index([org_id, site_id, drug_master_id, status], map: "FormularyChangeRequest_pending_guard_idx")
  @@index([status, created_at])
}

model FormularyTemplate {
  id             String   @id @default(cuid())
  org_id         String
  name           String
  description    String?
  source_site_id String?
  created_by_id  String
  items          Json
  item_count     Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([org_id, created_at])
  @@index([org_id, name])
}

// グローバルマスタ（org_id なし）
model GenericDrugMapping {
  id               String   @id @default(cuid())
  generic_name     String
  brand_drug_ids   Json // String[]
  price_comparison Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([generic_name])
}

// グローバル（org_id なし）
model DrugMasterImportLog {
  id           String       @id @default(cuid())
  source       ImportSource
  imported_at  DateTime     @default(now())
  record_count Int
  status       ImportStatus
  error_log    String?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  @@index([source, imported_at])
  @@index([status, imported_at])
}

// グローバルマスタ取込差分
model DrugMasterChangeEvent {
  id             String       @id @default(cuid())
  import_log_id  String?
  source         ImportSource
  yj_code        String
  drug_master_id String?
  change_type    String
  previous_value Json?
  current_value  Json?
  created_at     DateTime     @default(now())

  @@index([source, created_at])
  @@index([yj_code])
  @@index([change_type])
}
