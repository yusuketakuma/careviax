enum PrescriptionSourceType {
  paper
  fax
  e_prescription
  facility_batch
  refill
  qr_scan
}

enum MedicationCycleStatus {
  intake_received
  structuring
  inquiry_pending
  inquiry_resolved
  ready_to_dispense
  dispensing
  dispensed
  audit_pending
  audited
  setting
  set_audited
  visit_ready
  visit_completed
  reported
  on_hold
  cancelled
}

enum DispenseAuditResult {
  approved
  rejected
  hold
  emergency_approved
}

enum SetAuditResult {
  approved
  partial_approved
  rejected
}

enum PackagingInstructionTag {
  cold_storage
  narcotic
  half_tablet
  crush_prohibited
  separate_pack
  unit_dose
  staple_required
  label_required
  ptp
  mixing
  excipient
  decapsulation
  no_unit_dose
  manual_ptp
}

/// 調剤ワークベンチ 共通 NG 分類 (14種)。
/// 監査(SetAudit/SetBatch のセル単位)で差戻し理由を構造化する。
/// 注意: 既存の DispenseAudit.reject_reason_code (String?, 独自6種) は
/// この enum とは語彙が重ならず、TEXT のまま温存する (将来移行は値マッピング + データ移行が必要)。
enum RejectCode {
  patient_mismatch
  set_period_mismatch
  date_mismatch
  frequency_mismatch
  drug_mismatch
  quantity_short
  quantity_over
  discontinued_mixed
  washout_missed
  previous_drug_mixed
  outside_med_missing
  residual_instruction_missed
  photo_unclear
  undeterminable
}

/// SetBatch セル単位のセット状態 (一包化セットの進捗)。
enum SetCellState {
  pending
  set
  hold
}

/// SetBatch セル単位の監査状態 (quad-state: 未監査/OK/NG)。
enum SetAuditCellState {
  unaudited
  ok
  ng
}

/// 保留(ホールド)の適用範囲。
enum HoldScope {
  cycle
  line
  cell
}

/// 保留(ホールド)の理由分類。
enum HoldReason {
  prescription_change_wait
  doctor_confirm_wait
  residual_confirm_wait
  stock_shortage
  family_facility_confirm_wait
  onsite_set_at_visit
  other
}

model MedicationCycle {
  id                   String                @id @default(cuid())
  org_id               String
  case_id              String
  case_                CareCase              @relation(fields: [case_id], references: [id])
  patient_id           String
  overall_status       MedicationCycleStatus
  visit_sub_status     String? // 派生状態
  readiness_sub_status String?
  reporting_sub_status String?
  exception_status     String? // no_show/hospitalized/refused_receipt/awaiting_reply/report_failed/carry_items_partial
  version              Int                   @default(1) // 楽観的ロック
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt

  prescription_intakes     PrescriptionIntake[]
  inquiries                InquiryRecord[]
  dispense_tasks           DispenseTask[]
  set_plans                SetPlan[]
  workflow_exceptions      WorkflowException[]
  visit_schedules          VisitSchedule[]
  visit_schedule_proposals VisitScheduleProposal[]
  transition_logs          CycleTransitionLog[]
  packaging_groups         PackagingGroup[]
  cycle_holds              CycleHold[]

  @@index([org_id])
  @@index([case_id])
  @@index([overall_status])
}

model CycleTransitionLog {
  id          String          @id @default(cuid())
  org_id      String
  cycle_id    String
  cycle       MedicationCycle @relation(fields: [cycle_id], references: [id])
  from_status String
  to_status   String
  actor_id    String
  note        String?
  created_at  DateTime        @default(now())

  @@index([org_id])
  @@index([cycle_id, created_at])
}

model PrescriptionIntake {
  id                         String                 @id @default(cuid())
  org_id                     String
  cycle_id                   String
  cycle                      MedicationCycle        @relation(fields: [cycle_id], references: [id])
  source_type                PrescriptionSourceType
  external_prescription_id   String?
  rx_number                  String?
  prescribed_date            DateTime
  prescriber_name            String?
  prescriber_institution_id  String?
  prescriber_institution_ref PrescriberInstitution? @relation(fields: [prescriber_institution_id], references: [id])
  prescriber_institution     String?
  original_document_url      String? // S3
  prescription_category      String                 @default("regular") // regular | emergency
  emergency_category         String? // planned_disease_exacerbation | other_exacerbation | online (only when emergency)
  original_collected_at      DateTime?
  original_collected_by      String?
  refill_remaining_count     Int?
  refill_next_dispense_date  DateTime?
  split_dispense_total       Int?
  split_dispense_current     Int?
  split_next_dispense_date   DateTime?
  prescription_expiry_date   DateTime?
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt

  lines                      PrescriptionLine[]
  jahis_supplemental_records JahisSupplementalRecord[]

  @@unique([org_id, rx_number])
  @@unique([org_id, source_type, external_prescription_id])
  @@index([org_id])
  @@index([cycle_id])
  @@index([prescriber_institution_id])
}

model PrescriptionLine {
  id                                String                    @id @default(cuid())
  org_id                            String
  intake_id                         String
  intake                            PrescriptionIntake        @relation(fields: [intake_id], references: [id])
  line_number                       Int
  drug_name                         String
  drug_code                         String? // YJコード
  drug_master_id                    String?
  drug_master                       DrugMaster?               @relation("PrescriptionLineDrugMaster", fields: [drug_master_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  source_drug_code                  String?
  source_drug_code_type             String?
  drug_resolution_status            String?
  dosage_form                       String? // 錠剤/散剤/液剤/軟膏/貼付剤/坐剤/注射剤/吸入剤/点眼剤/点鼻剤 等
  dose                              String
  frequency                         String // 用法
  days                              Int // 投与日数
  quantity                          Float?
  unit                              String?
  is_generic                        Boolean                   @default(false)
  is_generic_name_prescription      Boolean                   @default(false)
  packaging_method                  PackagingMethod?
  packaging_instructions            String?
  packaging_instruction_tags        PackagingInstructionTag[] @default([])
  notes                             String?
  // 剤形分類・調剤方法
  route                             String? // internal(内服)/external(外用)/injection(注射)/other
  dispensing_method                 String? // standard(通常)/unit_dose(一包化)/crushed(粉砕)/other
  start_date                        DateTime?                 @db.Date // 服用開始日
  end_date                          DateTime?                 @db.Date // 服用終了日（start_date + days で自動計算可能）
  packaging_group_id                String?
  source_intake_id                  String?
  source_line_id                    String?
  source_intake_updated_at_snapshot DateTime?
  source_line_updated_at_snapshot   DateTime?
  created_at                        DateTime                  @default(now())
  updated_at                        DateTime                  @updatedAt

  inquiry_records      InquiryRecord[]
  dispense_results     DispenseResult[]
  dispensing_decisions DispensingDecision[]
  set_batches          SetBatch[]

  @@index([org_id])
  @@index([intake_id])
  @@index([drug_master_id])
  @@index([org_id, drug_master_id])
  @@index([org_id, drug_resolution_status])
  @@index([source_intake_id])
  @@index([source_line_id])
}

model InquiryRecord {
  id                   String            @id @default(cuid())
  org_id               String
  cycle_id             String
  cycle                MedicationCycle   @relation(fields: [cycle_id], references: [id])
  issue_id             String?
  issue                MedicationIssue?  @relation(fields: [issue_id], references: [id])
  line_id              String?
  line                 PrescriptionLine? @relation(fields: [line_id], references: [id])
  reason               String // 用量疑義/相互作用/禁忌/重複/その他
  inquiry_to_physician String
  inquiry_content      String
  result               String? // changed/unchanged/pending
  proposal_origin      String? // post_inquiry/pre_issuance
  residual_adjustment  Boolean?          @default(false)
  change_detail        String?
  inquired_at          DateTime
  resolved_at          DateTime?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  @@index([org_id])
  @@index([cycle_id])
  @@index([issue_id])
}

model DispenseTask {
  id          String          @id @default(cuid())
  org_id      String
  cycle_id    String
  cycle       MedicationCycle @relation(fields: [cycle_id], references: [id])
  assigned_to String? // User ID
  priority    String          @default("normal") // emergency/urgent/normal
  due_date    DateTime?
  status      String          @default("pending") // pending/in_progress/completed
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  results              DispenseResult[]
  audits               DispenseAudit[]
  dispensing_decisions DispensingDecision[]

  @@index([org_id])
  @@index([status])
}

model DispenseResult {
  id                 String           @id @default(cuid())
  org_id             String
  task_id            String
  task               DispenseTask     @relation(fields: [task_id], references: [id])
  line_id            String
  line               PrescriptionLine @relation(fields: [line_id], references: [id])
  actual_drug_name   String
  actual_drug_code   String?
  actual_quantity    Float
  actual_unit        String?
  discrepancy_reason String?
  carry_type         String // carry/facility_deposit/deferred
  special_notes      String? // 冷所/麻薬/半割等
  dispensed_by       String // User ID
  dispensed_at       DateTime
  version            Int              @default(1)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@unique([org_id, task_id, line_id])
  @@index([org_id])
  @@index([task_id])
}

model DispenseAudit {
  id                        String              @id @default(cuid())
  org_id                    String
  task_id                   String
  task                      DispenseTask        @relation(fields: [task_id], references: [id])
  result                    DispenseAuditResult
  reject_reason             String?
  reject_reason_code        String? // drug_name_mismatch | quantity_error | packaging_error | carry_type_error | labeling_error | other
  // NOTE: 後方互換のため TEXT のまま温存 (enum RejectCode とは語彙が重ならない)。
  // 将来 RejectCode へ移行する場合は値マッピング + 既存行のデータ移行が必要。
  reject_detail             String?
  audited_by                String // User ID
  audited_at                DateTime
  // --- 単独薬剤師の自己監査=限定例外 (D1=B)。既存行は NULL で後方互換。---
  // two-person rule の限定例外。調剤者=監査者の場合のみ admin 承認 + 理由必須。
  same_operator_reason      String? // 自己監査を要した理由 (必須入力, サーバ検証)
  same_operator_approved_by String? // 例外を承認した admin の User ID
  created_at                DateTime            @default(now())
  updated_at                DateTime            @updatedAt

  @@index([org_id])
  @@index([task_id])
  @@index([org_id, reject_reason_code])
}

/// DispensingDecision captures the pharmacist's confirmed dispensing method
/// BEFORE actual dispensing occurs.
///
/// Flow: PrescriptionLine (draft packaging fields from intake)
///     -> DispensingDecision (pharmacist confirms/adjusts method, packaging, temperature)
///     -> DispenseResult (records what was actually dispensed: drug name, quantity, carry type)
///
/// DispensingDecision answers "HOW to dispense" (method, packaging, temperature).
/// DispenseResult answers "WHAT was actually dispensed" (drug, quantity, outcome).
model DispensingDecision {
  id                         String                    @id @default(cuid())
  org_id                     String
  task_id                    String
  task                       DispenseTask              @relation(fields: [task_id], references: [id])
  line_id                    String
  line                       PrescriptionLine          @relation(fields: [line_id], references: [id])
  dispensing_method          String? // standard/unit_dose/crushed/other
  packaging_method           PackagingMethod?
  packaging_instructions     String?
  packaging_instruction_tags PackagingInstructionTag[] @default([])
  packaging_group_id         String?
  carry_type_override        String? // carry/facility_deposit/deferred
  special_handling_notes     String?
  temperature_category       String? // ambient/cold/frozen
  decided_by                 String // User ID
  decided_at                 DateTime
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @updatedAt

  @@unique([task_id, line_id])
  @@index([org_id])
  @@index([task_id])
  @@index([line_id])
}

model SetPlan {
  id                         String                 @id @default(cuid())
  org_id                     String
  cycle_id                   String
  cycle                      MedicationCycle        @relation(fields: [cycle_id], references: [id])
  target_period_start        DateTime
  target_period_end          DateTime
  set_method                 String // facility_calendar/four_times_daily/bedtime_only/custom
  packaging_method_id        String?
  packaging_method_ref       PackagingMethodMaster? @relation(fields: [packaging_method_id], references: [id], onDelete: SetNull)
  packaging_summary_snapshot Json?
  notes                      String?
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt

  batches     SetBatch[]
  audits      SetAudit[]
  change_logs SetBatchChangeLog[]

  @@unique([org_id, cycle_id, target_period_start, target_period_end, set_method])
  @@index([org_id])
  @@index([cycle_id])
  @@index([packaging_method_id])
}

model SetBatch {
  id                                  String                    @id @default(cuid())
  org_id                              String
  plan_id                             String
  plan                                SetPlan                   @relation(fields: [plan_id], references: [id])
  line_id                             String
  line                                PrescriptionLine          @relation(fields: [line_id], references: [id])
  slot                                String // morning/noon/evening/bedtime/prn
  day_number                          Int
  quantity                            Float
  carry_type                          String // carry/facility_deposit/deferred
  packaging_method_snapshot           PackagingMethod?
  packaging_instructions_snapshot     String?
  packaging_instruction_tags_snapshot PackagingInstructionTag[] @default([])
  packaging_group_id                  String?
  // --- 調剤ワークベンチ セル状態 (P0)。既存行は default/null で後方互換。---
  set_state                           SetCellState              @default(pending)
  audit_state                         SetAuditCellState         @default(unaudited)
  ng_code                             RejectCode?
  set_by                              String?
  set_at                              DateTime?
  audited_by                          String?
  audited_at                          DateTime?
  held_reason                         String?
  held_by                             String?
  held_at                             DateTime?
  version                             Int                       @default(1) // 楽観的ロック
  created_at                          DateTime                  @default(now())
  updated_at                          DateTime                  @updatedAt

  change_logs SetBatchChangeLog[]

  @@unique([org_id, plan_id, line_id, slot, day_number])
  @@index([org_id])
  @@index([plan_id])
}

model SetAudit {
  id                        String         @id @default(cuid())
  org_id                    String
  plan_id                   String
  plan                      SetPlan        @relation(fields: [plan_id], references: [id])
  result                    SetAuditResult
  approved_scope            Json? // 部分承認の範囲
  reject_reason             String?
  // --- セット監査 3ペイン再構築 (p0_15): 写真確認 + 6項目チェックリスト ---
  // 既存行は NULL/空配列で後方互換。
  checklist                 Json? // 6項目チェックリストの結果 [{ key, label, checked }]
  photo_asset_ids           String[]       @default([]) // 確認した写真 (FileAsset.id, purpose=set-photo)
  audited_by                String // User ID
  audited_at                DateTime
  // --- 単独薬剤師の自己監査=限定例外 (D1=B)。既存行は NULL で後方互換。---
  // two-person rule の限定例外。実施者=監査者の場合のみ admin 承認 + 理由必須。
  same_operator_reason      String? // 自己監査を要した理由 (必須入力, サーバ検証)
  same_operator_approved_by String? // 例外を承認した admin の User ID
  created_at                DateTime       @default(now())
  updated_at                DateTime       @updatedAt

  @@index([org_id])
  @@index([plan_id])
}

model SetBatchChangeLog {
  id              String    @id @default(cuid())
  org_id          String
  plan_id         String
  plan            SetPlan   @relation(fields: [plan_id], references: [id])
  batch_id        String?
  batch           SetBatch? @relation(fields: [batch_id], references: [id], onDelete: SetNull)
  action          String
  trigger_source  String?
  reason          String?
  line_ids        Json?
  before_snapshot Json
  after_snapshot  Json?
  changed_by      String?
  created_at      DateTime  @default(now())

  @@index([org_id])
  @@index([plan_id, created_at])
  @@index([batch_id])
}

/// 調剤ワークベンチ 一包化グループ (P0)。
/// PrescriptionLine.packaging_group_id (String?, loose) と group_key で対応させる。
/// 既存の loose 参照列は型変更/FK 化しない (破壊的回避)。
model PackagingGroup {
  id         String          @id @default(cuid())
  org_id     String
  cycle_id   String
  cycle      MedicationCycle @relation(fields: [cycle_id], references: [id])
  group_key  String
  label      String
  slot       String?
  method     String
  sort_order Int
  version    Int             @default(0)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  @@unique([org_id, cycle_id, group_key])
  @@index([org_id, cycle_id])
}

/// 調剤ワークベンチ 保留(ホールド)記録 (P0)。
/// cycle / line / cell 単位で保留理由・期限・担当・解消を構造化する。
model CycleHold {
  id            String          @id @default(cuid())
  org_id        String
  cycle_id      String
  cycle         MedicationCycle @relation(fields: [cycle_id], references: [id])
  phase         String
  scope         HoldScope
  line_id       String?
  day_number    Int?
  slot          String?
  reason        HoldReason
  reason_detail String?
  due_at        DateTime?
  assigned_to   String?
  resolved_at   DateTime?
  resolved_by   String?
  note          String?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  @@index([org_id, cycle_id])
}

model WorkflowException {
  id             String           @id @default(cuid())
  org_id         String
  cycle_id       String?
  cycle          MedicationCycle? @relation(fields: [cycle_id], references: [id])
  patient_id     String?
  patient        Patient?         @relation(fields: [patient_id], references: [id])
  exception_type String
  description    String
  severity       String // critical/warning/info
  status         String           @default("open") // open/resolved/dismissed
  resolved_by    String?
  resolved_at    DateTime?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  @@index([org_id])
  @@index([patient_id])
  @@index([status])
}

enum QrDraftStatus {
  pending
  confirmed
  discarded
}

model QrScanDraft {
  id                  String        @id @default(cuid())
  org_id              String
  site_id             String
  patient_id          String?
  scanned_by          String
  session_id          String
  status              QrDraftStatus @default(pending)
  schema_version      Int           @default(1)
  raw_qr_texts        Json // String[]
  qr_payload_hash     String?
  parsed_data         Json // JahisQRData
  parse_errors        Json? // JahisParseError[]
  auto_completed      Json? // AutoCompletedField[]
  expected_qr_count   Int?
  confirmed_intake_id String?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  jahis_supplemental_records JahisSupplementalRecord[]

  @@index([org_id])
  @@index([org_id, status])
  @@index([org_id, qr_payload_hash])
  @@index([session_id])
  @@index([patient_id])
}

model JahisSupplementalRecord {
  id                     String              @id @default(cuid())
  org_id                 String
  patient_id             String?
  patient                Patient?            @relation(fields: [patient_id], references: [id], onDelete: SetNull)
  qr_draft_id            String?
  qr_draft               QrScanDraft?        @relation(fields: [qr_draft_id], references: [id], onDelete: SetNull)
  prescription_intake_id String?
  prescription_intake    PrescriptionIntake? @relation(fields: [prescription_intake_id], references: [id], onDelete: SetNull)
  record_type            String
  record_label           String
  line_number            Int
  summary                String?
  payload                Json
  raw_line               String
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt

  @@index([org_id])
  @@index([patient_id])
  @@index([qr_draft_id])
  @@index([prescription_intake_id])
  @@index([record_type])
}
