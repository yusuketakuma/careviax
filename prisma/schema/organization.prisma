enum MemberRole {
  owner
  admin
  pharmacist
  pharmacist_trainee
  clerk
  driver
  external_viewer
}

enum FacilityTypeEnum {
  nursing_home
  group_home
  assisted_living
  clinic
  hospital
  day_service
  home
  other
}

enum ProfessionTypeEnum {
  physician
  nurse
  care_manager
  medical_social_worker
  physical_therapist
  occupational_therapist
  speech_therapist
  registered_dietitian
  dentist
  dental_hygienist
  home_helper
  care_staff
  other
}

enum HolidayType {
  public_holiday
  site_closure
  org_event
}

enum UserAccountStatus {
  invited
  active
  suspended
  retired
}

model Organization {
  id               String  @id @default(cuid())
  name             String
  corporate_number String? @unique // 法人番号
  address          String?
  phone            String?
  email            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  sites                 PharmacySite[]
  memberships           Membership[]
  facilities            Facility[]
  external_professionals ExternalProfessional[]

  @@index([name])
}

model PharmacySite {
  id      String       @id @default(cuid())
  org_id  String
  org     Organization @relation(fields: [org_id], references: [id])
  name    String
  address String
  phone   String?
  fax     String?
  lat     Float?
  lng     Float?
  // 届出フラグ
  is_health_support_pharmacy Boolean @default(false) // 健康サポート薬局
  is_regional_support        Boolean @default(false) // 地域連携薬局
  is_specialized_pharmacy    Boolean @default(false) // 専門医療機関連携薬局
  // 体制加算区分
  dispensing_fee_category String? // 調剤基本料区分
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  memberships          Membership[]
  pharmacist_shifts    PharmacistShift[]
  pharmacist_shift_templates PharmacistShiftTemplate[]
  facility_standards   FacilityStandardRegistration[]
  drug_stocks          PharmacyDrugStock[]
  visit_schedules      VisitSchedule[]
  visit_schedule_proposals VisitScheduleProposal[]
  business_holidays    BusinessHoliday[]
  insurance_configs    PharmacySiteInsuranceConfig[]

  @@index([org_id])
}

/// 薬局情報 — 保険種別×改定年度ごとの算定設定
/// 調剤基本料、各種体制加算、施設基準に基づく届出状況を期間付きで管理。
/// 改定年度ごとにレコードを作成し、effective_from/to で自動切り替え。
model PharmacySiteInsuranceConfig {
  id               String       @id @default(cuid())
  org_id           String
  site_id          String
  site             PharmacySite @relation(fields: [site_id], references: [id])

  /// 保険種別: medical(医療保険) / care(介護保険)
  insurance_type   String       // 'medical' | 'care'
  /// 改定年度コード (e.g., '2024')
  revision_code    String
  /// 改定名称 (e.g., '令和6年度 診療報酬改定')
  revision_label   String?

  /// 施行日
  effective_from   DateTime     @db.Date
  /// 終了日 (null = 現行)
  effective_to     DateTime?    @db.Date

  // ════════════════════════════════════════════
  // 医療保険: 調剤基本料（処方箋受付1回につき）
  // ════════════════════════════════════════════
  /// 調剤基本料区分: basic_1(45点) / basic_2(29点) / basic_3_i(24点) /
  ///   basic_3_ro(19点) / basic_3_ha(35点) / special_a(5点) / special_b(3点)
  dispensing_fee_category  String?

  // ════════════════════════════════════════════
  // 医療保険: 体制加算（処方箋受付1回につき）
  // ════════════════════════════════════════════
  /// 地域支援体制加算: none / level_1(32点) / level_2(40点) / level_3(10点) / level_4(32点)
  regional_support_level   String?
  /// 後発医薬品調剤体制加算: none / level_1(21点) / level_2(28点) / level_3(30点)
  generic_dispensing_level  String?
  /// 連携強化加算 (5点)
  cooperation_enhancement   Boolean @default(false)
  /// 医療DX推進体制整備加算 (4点)
  medical_dx_promotion      Boolean @default(false)

  // ════════════════════════════════════════════
  // 医療保険: 在宅関連体制加算（訪問1回につき）
  // ════════════════════════════════════════════
  /// 在宅薬学総合体制加算: none / level_1(15点) / level_2(50点)
  home_comprehensive_level  String?

  // ════════════════════════════════════════════
  // 共通: 免許・許可
  // ════════════════════════════════════════════
  /// 麻薬小売業者の免許
  narcotic_dealer_license          Boolean @default(false)
  /// 高度管理医療機器販売業の許可
  high_care_medical_device_license Boolean @default(false)

  // ════════════════════════════════════════════
  // 介護保険: 地域加算
  // ════════════════════════════════════════════
  /// 特別地域加算 (15%) の対象
  region_special_15       Boolean @default(false)
  /// 中山間地域等における小規模事業所加算 (10%)
  region_small_office_10  Boolean @default(false)
  /// 中山間地域等に居住する者へのサービス提供加算 (5%)
  region_resident_5       Boolean @default(false)

  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  @@unique([org_id, site_id, insurance_type, revision_code])
  @@index([org_id])
  @@index([site_id])
}

model User {
  id                  String            @id @default(cuid())
  org_id              String
  cognito_sub         String            @unique // Cognito User Pool の sub
  cognito_username    String?           @unique
  email               String            @unique
  name                String
  name_kana           String?
  phone               String?
  default_site_id     String?
  max_daily_visits    Int?
  max_weekly_visits   Int?
  max_travel_minutes  Int?
  visit_specialties   Json?
  coverage_area       Json?
  can_accept_emergency Boolean          @default(true)
  is_active           Boolean           @default(true)
  account_status      UserAccountStatus @default(invited)
  invited_at          DateTime?
  invited_by          String?
  last_invited_at     DateTime?
  activated_at        DateTime?
  deactivated_at      DateTime?
  deactivation_reason String?
  session_version     Int               @default(0)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  memberships  Membership[]
  credentials  PharmacistCredential[]
  shifts       PharmacistShift[]
  shift_templates PharmacistShiftTemplate[]

  @@index([org_id])
  @@index([cognito_sub])
  @@index([account_status])
}

model Membership {
  id                 String        @id @default(cuid())
  org_id             String
  org                Organization  @relation(fields: [org_id], references: [id])
  user_id            String
  user               User          @relation(fields: [user_id], references: [id])
  site_id            String?
  site               PharmacySite? @relation(fields: [site_id], references: [id])
  role               MemberRole
  can_dispense       Boolean @default(false)
  can_audit_dispense Boolean @default(false)
  can_set            Boolean @default(false)
  can_audit_set      Boolean @default(false)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([user_id, org_id, site_id])
  @@index([org_id])
}

model FacilityStandardRegistration {
  id                   String       @id @default(cuid())
  org_id               String
  site_id              String
  site                 PharmacySite @relation(fields: [site_id], references: [id])
  standard_type        String // 届出種別
  filed_date           DateTime // 届出日
  effective_date       DateTime? // 有効日
  expiry_date          DateTime? // 有効期限
  renewal_alert_date   DateTime? // 更新期限アラート日
  requirements_status  Json? // 要件達成状態
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([org_id])
  @@index([site_id])
}

model PharmacistCredential {
  id                   String   @id @default(cuid())
  org_id               String
  user_id              String
  user                 User     @relation(fields: [user_id], references: [id])
  certification_type   String // 研修認定証タイプ
  certification_number String?
  issued_date          DateTime?
  expiry_date          DateTime?
  tenure_years         Float? // 在籍継続年数
  weekly_work_hours    Float? // 週勤務時間実績
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([org_id])
  @@index([user_id])
}

model PharmacistShift {
  id             String       @id @default(cuid())
  org_id         String
  site_id        String
  site           PharmacySite @relation(fields: [site_id], references: [id])
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  date           DateTime     @db.Date
  available      Boolean      @default(true)
  available_from DateTime?    @db.Time()
  available_to   DateTime?    @db.Time()
  note           String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@unique([user_id, date])
  @@index([org_id])
  @@index([site_id, date])
}

model PharmacistShiftTemplate {
  id             String       @id @default(cuid())
  org_id         String
  site_id        String
  site           PharmacySite @relation(fields: [site_id], references: [id])
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  weekday        Int
  available      Boolean      @default(true)
  available_from DateTime?    @db.Time()
  available_to   DateTime?    @db.Time()
  note           String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@unique([user_id, weekday])
  @@index([org_id, weekday])
}

model BusinessHoliday {
  id           String       @id @default(cuid())
  org_id       String
  site_id      String?
  site         PharmacySite? @relation(fields: [site_id], references: [id])
  date         DateTime     @db.Date
  name         String
  holiday_type HolidayType
  is_closed    Boolean      @default(true)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  @@index([org_id, date])
  @@index([site_id, date])
}

// PharmacyDrugStock は drug.prisma で定義予定（未実装時はコメントアウト）
// model PharmacyDrugStock は他ファイルで定義

model Facility {
  id            String          @id @default(cuid())
  org_id        String
  org           Organization    @relation(fields: [org_id], references: [id])
  name          String
  facility_type FacilityTypeEnum
  address       String?
  phone         String?
  fax           String?
  notes         String?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @default(now()) @updatedAt

  contacts FacilityContact[]

  @@unique([org_id, name])
  @@index([org_id])
}

model FacilityContact {
  id          String   @id @default(cuid())
  org_id      String
  facility_id String
  facility    Facility @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  name        String
  role        String?
  phone       String?
  email       String?
  fax         String?
  is_primary  Boolean  @default(false)
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@index([org_id])
  @@index([facility_id])
}

model ExternalProfessional {
  id                String             @id @default(cuid())
  org_id            String
  org               Organization       @relation(fields: [org_id], references: [id])
  profession_type   ProfessionTypeEnum
  name              String
  organization_name String?
  department        String?
  phone             String?
  email             String?
  fax               String?
  address           String?
  notes             String?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @default(now()) @updatedAt

  @@index([org_id])
  @@index([profession_type])
}
