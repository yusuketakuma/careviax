enum MemberRole {
  owner
  admin
  pharmacist
  pharmacist_trainee
  clerk
  driver
  external_viewer
}

enum FacilityTypeEnum {
  nursing_home
  group_home
  assisted_living
  clinic
  hospital
  day_service
  home
  other
}

enum ProfessionTypeEnum {
  physician
  nurse
  care_manager
  medical_social_worker
  physical_therapist
  occupational_therapist
  speech_therapist
  registered_dietitian
  dentist
  dental_hygienist
  home_helper
  care_staff
  other
}

enum HolidayType {
  public_holiday
  site_closure
  org_event
}

enum UserAccountStatus {
  pending_cognito
  invited
  active
  suspended
  retired
  cognito_failed
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  corporate_number String?  @unique // 法人番号
  address          String?
  phone            String?
  email            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  sites                        PharmacySite[]
  memberships                  Membership[]
  facilities                   Facility[]
  external_professionals       ExternalProfessional[]
  prescriber_institutions      PrescriberInstitution[]
  pca_pumps                    PcaPump[]
  pca_pump_rentals             PcaPumpRental[]
  pca_pump_rental_accessories  PcaPumpRentalAccessory[]
  pca_pump_maintenance_events  PcaPumpMaintenanceEvent[]
  service_areas                ServiceArea[]
  visit_vehicle_resources      VisitVehicleResource[]
  webhook_registrations        WebhookRegistration[]
  webhook_deliveries           WebhookDelivery[]
  drug_alert_rules             DrugAlertRule[]
  file_assets                  FileAsset[]
  visitScheduleProposalBatches VisitScheduleProposalBatch[]
  partner_pharmacies           PartnerPharmacy[]
  pharmacy_partnerships        PharmacyPartnership[]
  patient_share_cases          PatientShareCase[]
  patient_share_consents       PatientShareConsent[]
  patient_links                PatientLink[]
  patient_share_corrections    PatientShareCorrectionRequest[]
  pharmacy_visit_requests      PharmacyVisitRequest[]
  pharmacy_message_threads     PharmacyCooperationMessageThread[]
  pharmacy_messages            PharmacyCooperationMessage[]
  partner_visit_records        PartnerVisitRecord[]
  claim_cooperation_notes      ClaimCooperationNote[]
  pharmacy_contracts           PharmacyContract[]
  pharmacy_contract_versions   PharmacyContractVersion[]
  pharmacy_contract_fee_rules  PharmacyContractFeeRule[]
  visit_billing_candidates     VisitBillingCandidate[]
  pharmacy_invoices            PharmacyInvoice[]
  pharmacy_invoice_items       PharmacyInvoiceItem[]
  contract_documents           ContractDocument[]

  @@index([name])
}

model PharmacySite {
  id                         String       @id @default(cuid())
  org_id                     String
  org                        Organization @relation(fields: [org_id], references: [id])
  name                       String
  address                    String
  phone                      String?
  fax                        String?
  lat                        Float?
  lng                        Float?
  // 届出フラグ
  is_health_support_pharmacy Boolean      @default(false) // 健康サポート薬局
  is_regional_support        Boolean      @default(false) // 地域連携薬局
  is_specialized_pharmacy    Boolean      @default(false) // 専門医療機関連携薬局
  // 体制加算区分
  dispensing_fee_category    String? // 調剤基本料区分
  created_at                 DateTime     @default(now())
  updated_at                 DateTime     @updatedAt

  memberships                Membership[]
  pharmacist_shifts          PharmacistShift[]
  pharmacist_shift_templates PharmacistShiftTemplate[]
  facility_standards         FacilityStandardRegistration[]
  drug_stocks                PharmacyDrugStock[]
  visit_schedules            VisitSchedule[]
  visit_schedule_proposals   VisitScheduleProposal[]
  business_holidays          BusinessHoliday[]
  insurance_configs          PharmacySiteInsuranceConfig[]
  service_areas              ServiceArea[]
  visit_vehicle_resources    VisitVehicleResource[]
  base_pharmacy_partnerships PharmacyPartnership[]          @relation("BaseSitePharmacyPartnerships")

  @@unique([id, org_id])
  @@index([org_id])
}

model ServiceArea {
  id         String       @id @default(cuid())
  org_id     String
  org        Organization @relation(fields: [org_id], references: [id])
  site_id    String
  site       PharmacySite @relation(fields: [site_id], references: [id])
  name       String
  area_type  String // radius/polygon
  geo_data   Json
  notes      String?
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  @@index([org_id])
  @@index([site_id])
  @@index([area_type])
}

/// 薬局情報 — 保険種別×改定年度ごとの算定設定
/// 調剤基本料、各種体制加算、施設基準に基づく届出状況を期間付きで管理。
/// 改定年度ごとにレコードを作成し、effective_from/to で自動切り替え。
///
/// config (Json) の型は TypeScript 側で改定年度ごとに定義:
///   medical: MedicalSiteConfig2024 (types.ts)
///   care:    CareSiteConfig2024    (types.ts)
/// DB スキーマを改定ごとに変更する必要がない設計。
model PharmacySiteInsuranceConfig {
  id      String       @id @default(cuid())
  org_id  String
  site_id String
  site    PharmacySite @relation(fields: [site_id], references: [id])

  /// 保険種別: medical(医療保険) / care(介護保険)
  insurance_type String // 'medical' | 'care'
  /// 改定年度コード (e.g., '2024')
  revision_code  String
  /// 改定名称 (e.g., '令和6年度 診療報酬改定')
  revision_label String?

  /// 施行日
  effective_from DateTime  @db.Date
  /// 終了日 (null = 現行)
  effective_to   DateTime? @db.Date

  /// 改定固有の設定 (TypeScript 側で改定年度ごとの型を適用)
  config Json @default("{}")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([org_id, site_id, insurance_type, revision_code])
  @@index([org_id])
  @@index([site_id])
}

model User {
  id                   String            @id @default(cuid())
  org_id               String
  cognito_sub          String            @unique // Cognito User Pool の sub
  cognito_username     String?           @unique
  email                String            @unique
  name                 String
  name_kana            String?
  phone                String?
  default_site_id      String?
  max_daily_visits     Int?
  max_weekly_visits    Int?
  max_travel_minutes   Int?
  visit_specialties    Json?
  coverage_area        Json?
  can_accept_emergency Boolean           @default(true)
  is_active            Boolean           @default(true)
  account_status       UserAccountStatus @default(invited)
  invited_at           DateTime?
  invited_by           String?
  last_invited_at      DateTime?
  activated_at         DateTime?
  deactivated_at       DateTime?
  deactivation_reason  String?
  session_version      Int               @default(0)
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt

  memberships     Membership[]
  credentials     PharmacistCredential[]
  shifts          PharmacistShift[]
  shift_templates PharmacistShiftTemplate[]

  @@index([org_id])
  @@index([cognito_sub])
  @@index([account_status])
}

model Membership {
  id                 String        @id @default(cuid())
  org_id             String
  org                Organization  @relation(fields: [org_id], references: [id])
  user_id            String
  user               User          @relation(fields: [user_id], references: [id])
  site_id            String?
  site               PharmacySite? @relation(fields: [site_id], references: [id])
  role               MemberRole
  can_dispense       Boolean       @default(false)
  can_audit_dispense Boolean       @default(false)
  can_set            Boolean       @default(false)
  can_audit_set      Boolean       @default(false)
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  @@unique([user_id, org_id, site_id])
  @@index([org_id])
}

model FacilityStandardRegistration {
  id                  String       @id @default(cuid())
  org_id              String
  site_id             String
  site                PharmacySite @relation(fields: [site_id], references: [id])
  standard_type       String // 届出種別
  filed_date          DateTime // 届出日
  effective_date      DateTime? // 有効日
  expiry_date         DateTime? // 有効期限
  renewal_alert_date  DateTime? // 更新期限アラート日
  requirements_status Json? // 要件達成状態
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@index([org_id])
  @@index([site_id])
}

model PharmacistCredential {
  id                   String    @id @default(cuid())
  org_id               String
  user_id              String
  user                 User      @relation(fields: [user_id], references: [id])
  certification_type   String // 研修認定証タイプ
  certification_number String?
  issued_date          DateTime?
  expiry_date          DateTime?
  tenure_years         Float? // 在籍継続年数
  weekly_work_hours    Float? // 週勤務時間実績
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@index([org_id])
  @@index([user_id])
}

model PharmacistShift {
  id             String       @id @default(cuid())
  org_id         String
  site_id        String
  site           PharmacySite @relation(fields: [site_id], references: [id])
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  date           DateTime     @db.Date
  available      Boolean      @default(true)
  available_from DateTime?    @db.Time()
  available_to   DateTime?    @db.Time()
  note           String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@unique([user_id, date])
  @@index([org_id])
  @@index([site_id, date])
}

model PharmacistShiftTemplate {
  id             String       @id @default(cuid())
  org_id         String
  site_id        String
  site           PharmacySite @relation(fields: [site_id], references: [id])
  user_id        String
  user           User         @relation(fields: [user_id], references: [id])
  weekday        Int
  available      Boolean      @default(true)
  available_from DateTime?    @db.Time()
  available_to   DateTime?    @db.Time()
  note           String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  @@unique([user_id, weekday])
  @@index([org_id, weekday])
}

model BusinessHoliday {
  id           String        @id @default(cuid())
  org_id       String
  site_id      String?
  site         PharmacySite? @relation(fields: [site_id], references: [id])
  date         DateTime      @db.Date
  name         String
  holiday_type HolidayType
  is_closed    Boolean       @default(true)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@index([org_id, date])
  @@index([site_id, date])
}

// PharmacyDrugStock は drug.prisma で定義予定（未実装時はコメントアウト）
// model PharmacyDrugStock は他ファイルで定義

model Facility {
  id                     String           @id @default(cuid())
  org_id                 String
  org                    Organization     @relation(fields: [org_id], references: [id])
  name                   String
  facility_type          FacilityTypeEnum
  address                String?
  phone                  String?
  fax                    String?
  acceptance_time_from   DateTime?        @db.Time()
  acceptance_time_to     DateTime?        @db.Time()
  regular_visit_weekdays Json?
  notes                  String?
  /// 総戸数（マンション）またはユニット数（施設）。特例判定に使用
  total_units            Int?
  created_at             DateTime         @default(now())
  updated_at             DateTime         @default(now()) @updatedAt

  contacts               FacilityContact[]
  units                  FacilityUnit[]
  residences             Residence[]
  external_professionals ExternalProfessional[]

  @@unique([org_id, name])
  @@index([org_id])
}

/// 施設内のユニット（フロア/棟/ユニット）
/// グループホーム: ユニット単位で単一建物患者数をカウント（3ユニット以下）
/// 老健/有料老人ホーム: 訪問グルーピング用（算定は建物単位）
model FacilityUnit {
  id            String   @id @default(cuid())
  org_id        String
  facility_id   String
  facility      Facility @relation(fields: [facility_id], references: [id])
  name          String // e.g., "2F東ユニット"
  floor         String? // e.g., "2F"
  unit_type     String   @default("unit") // floor / wing / unit
  capacity      Int? // 定員
  notes         String?
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  residences             Residence[]
  visit_schedules        VisitSchedule[]
  facility_visit_batches FacilityVisitBatch[]

  @@unique([org_id, facility_id, name])
  @@index([org_id])
  @@index([facility_id])
}

model FacilityContact {
  id                       String                @id @default(cuid())
  org_id                   String
  facility_id              String
  facility                 Facility              @relation(fields: [facility_id], references: [id], onDelete: Cascade)
  name                     String
  role                     String?
  phone                    String?
  email                    String?
  fax                      String?
  preferred_contact_method CommunicationChannel?
  preferred_contact_time   String?
  last_contacted_at        DateTime?
  last_success_channel     CommunicationChannel?
  is_primary               Boolean               @default(false)
  notes                    String?
  created_at               DateTime              @default(now())
  updated_at               DateTime              @default(now()) @updatedAt

  @@index([org_id])
  @@index([facility_id])
}

model ExternalProfessional {
  id                       String                @id @default(cuid())
  org_id                   String
  org                      Organization          @relation(fields: [org_id], references: [id])
  profession_type          ProfessionTypeEnum
  name                     String
  organization_name        String?
  department               String?
  facility_id              String?
  facility                 Facility?             @relation(fields: [facility_id], references: [id])
  phone                    String?
  email                    String?
  fax                      String?
  preferred_contact_method CommunicationChannel?
  preferred_contact_time   String?
  last_contacted_at        DateTime?
  last_success_channel     CommunicationChannel?
  address                  String?
  notes                    String?
  created_at               DateTime              @default(now())
  updated_at               DateTime              @default(now()) @updatedAt
  care_team_links          CareTeamLink[]

  @@index([org_id])
  @@index([profession_type])
  @@index([facility_id])
}

model PrescriberInstitution {
  id                       String                @id @default(cuid())
  org_id                   String
  org                      Organization          @relation(fields: [org_id], references: [id])
  name                     String
  institution_code         String?
  address                  String?
  phone                    String?
  fax                      String?
  preferred_contact_method CommunicationChannel?
  preferred_contact_time   String?
  last_contacted_at        DateTime?
  last_success_channel     CommunicationChannel?
  notes                    String?
  created_at               DateTime              @default(now())
  updated_at               DateTime              @default(now()) @updatedAt

  prescription_intakes PrescriptionIntake[]
  pca_pump_rentals     PcaPumpRental[]

  @@unique([id, org_id])
  @@unique([org_id, name])
  @@index([org_id])
  @@index([institution_code])
}
