enum PayerBasis {
  medical
  care
  self_pay
  non_billable
}

enum NotificationType {
  urgent
  business
  reminder
  system
}

enum SettingScope {
  system
  organization
  site
  user
}

model NotificationRule {
  id          String   @id @default(cuid())
  org_id      String
  event_type  String
  channel     String   // in_app/email
  recipients  Json
  enabled     Boolean  @default(true)
  conditions  Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([org_id])
  @@index([event_type])
  @@index([enabled])
}

model BillingRule {
  id                    String      @id @default(cuid())
  org_id                String
  ssot_key              String?
  billing_scope         String      @default("custom") // home_care_ssot/custom_override
  rule_type             String      // base/addition/regional_addition/reduction
  service_type          String      @default("generic") // medical_home_visit/care_home_management
  payer_basis           PayerBasis?
  provider_scope        String?     // pharmacy/hospital_clinic
  selection_mode        String      @default("manual") // auto/manual
  calculation_unit      String      @default("point") // point/unit/percent
  display_order         Int         @default(0)
  name                  String
  code                  String?
  conditions            Json?
  evidence_requirements Json?
  source_url            String?
  source_note           String?
  amount                Int         @default(0)
  effective_from        DateTime?   @db.Date
  effective_to          DateTime?   @db.Date
  is_system             Boolean     @default(false)
  is_active             Boolean     @default(true)
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  @@index([org_id])
  @@index([rule_type])
  @@index([billing_scope])
  @@index([service_type])
  @@index([is_active])
  @@unique([org_id, ssot_key])
}

model BillingCandidate {
  id                  String   @id @default(cuid())
  org_id              String
  patient_id          String
  cycle_id            String?
  evidence_id         String?
  rule_id             String?
  dedupe_key          String?
  billing_month       DateTime @db.Date // YYYY-MM-01
  billing_code        String
  billing_name        String
  points              Int?
  quantity            Int      @default(1)
  calculation_breakdown Json?
  source_snapshot     Json?
  status              String   @default("candidate") // candidate/confirmed/excluded/exported
  exclusion_reason    String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([org_id])
  @@index([billing_month])
  @@index([status])
  @@unique([org_id, dedupe_key])
}

model BillingEvidence {
  id                         String     @id @default(cuid())
  org_id                     String
  visit_record_id            String
  patient_id                 String?
  cycle_id                   String?
  billing_month              DateTime?  @db.Date
  payer_basis                PayerBasis
  billing_service_type       String?    // medical_home_visit/care_home_management
  provider_scope             String?    // pharmacy/hospital_clinic
  claimable                  Boolean    @default(false)
  exclusion_reason           String?
  order_ref                  String?
  consent_ref                String?
  management_plan_ref        String?
  report_delivery_ref        String?
  visit_record_ref           String?
  building_patient_count     Int?
  monthly_count_snapshot     Int?
  weekly_count_snapshot      Int?
  applied_rule_keys          Json?
  recommended_rule_keys      Json?
  calculation_context        Json?
  same_month_exclusion_flags Json?
  validation_notes           String?
  created_at                 DateTime   @default(now())
  updated_at                 DateTime   @updatedAt

  @@index([org_id])
  @@index([visit_record_id])
  @@index([billing_month])
  @@index([cycle_id])
  @@unique([org_id, visit_record_id])
}

model Notification {
  id         String           @id @default(cuid())
  org_id     String
  user_id    String
  event_type String?
  type       NotificationType
  title      String
  message    String
  link       String?
  metadata   Json?
  dedupe_key String?
  is_read    Boolean          @default(false)
  read_at    DateTime?
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  @@index([org_id])
  @@index([user_id])
  @@index([is_read])
  @@index([event_type])
  @@unique([org_id, user_id, dedupe_key])
}

model AuditLog {
  id          String   @id @default(cuid())
  org_id      String
  actor_id    String // User ID
  action      String
  target_type String
  target_id   String
  changes     Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([org_id])
  @@index([actor_id])
  @@index([target_type])
  @@index([created_at])
}

model IntegrationJob {
  id          String    @id @default(cuid())
  org_id      String?
  job_type    String
  dedupe_key  String?
  status      String    @default("pending") // pending/running/completed/failed
  input       Json?
  output      Json?
  error_log   String?
  run_at      DateTime?
  locked_at   DateTime?
  started_at  DateTime?
  completed_at DateTime?
  retry_count Int       @default(0)
  max_retries Int       @default(3)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([job_type])
  @@index([status])
  @@index([run_at])
  @@unique([job_type, org_id, dedupe_key])
}

model Template {
  id            String   @id @default(cuid())
  org_id        String
  name          String
  template_type String // care_report/tracing_report/management_plan/medication_calendar
  content       Json
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([org_id])
  @@index([template_type])
}

model Setting {
  id         String       @id @default(cuid())
  scope      SettingScope
  scope_id   String? // org_id or site_id or user_id
  key        String
  value      Json
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  @@unique([scope, scope_id, key])
  @@index([scope, scope_id])
}

model LabelDictionary {
  id         String   @id @default(cuid())
  key        String   @unique
  label_ja   String
  label_en   String?
  category   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([category])
}

model UatFeedback {
  id                  String   @id @default(cuid())
  org_id              String
  submitted_by        String?
  priority            String
  feedback            String
  checklist_progress  String?
  checked_items       Json?
  source              String   @default("pilot_pharmacy")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([org_id])
  @@index([priority])
}

model SourceOfTruthMatrix {
  id                 String   @id @default(cuid())
  org_id             String
  entity_type        String // patient/prescription/dispense/carry_items/report_delivery/billing
  source_of_truth    String // careviax/external
  sync_direction     String? // push/pull/bidirectional
  external_system    String?
  recovery_procedure String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([org_id, entity_type])
}
