model PatientInsurance {
  id                       String                     @id @default(cuid())
  org_id                   String
  display_id               String?
  patient_id               String
  patient                  Patient                    @relation(fields: [patient_id], references: [id])
  insurance_type           InsuranceType
  application_status       InsuranceApplicationStatus @default(confirmed)
  insurer_number           String? // 保険者番号 / 公費負担者番号
  public_program_code      String? // 法別番号（例: 21, 54）
  symbol                   String? // 記号
  number                   String? // 番号 / 公費受給者番号
  branch_number            String? // 枝番
  copay_ratio              Int? // 自己負担割合（例: 30 = 3割）
  valid_from               DateTime?                  @db.Date
  valid_until              DateTime?                  @db.Date
  application_submitted_at DateTime?                  @db.Date
  decision_at              DateTime?                  @db.Date
  previous_care_level      String?
  provisional_care_level   String?
  confirmed_care_level     String?
  is_active                Boolean                    @default(true)
  notes                    String?
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([patient_id, insurance_type, is_active])
  @@index([patient_id, application_status, is_active])
}

model PatientLabObservation {
  id                     String         @id @default(cuid())
  org_id                 String
  display_id             String?
  patient_id             String
  patient                Patient        @relation(fields: [patient_id], references: [id])
  analyte_code           LabAnalyteCode
  measured_at            DateTime
  value_numeric          Float?
  value_text             String?
  unit                   String?
  abnormal_flag          String? // "H" | "L" | "HH" | "LL" | "A"
  reference_low          Float?
  reference_high         Float?
  source_type            String // "manual" | "visit_record" | "import"
  source_visit_record_id String?
  note                   String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id, analyte_code, measured_at])
  @@index([source_visit_record_id])
}

model PatientMcsMessage {
  id                  String         @id @default(cuid())
  org_id              String
  display_id          String?
  patient_id          String
  patient             Patient        @relation(fields: [patient_id], references: [id])
  link_id             String
  link                PatientMcsLink @relation(fields: [link_id], references: [id], onDelete: Cascade)
  source_message_id   String
  author_name         String
  author_role         String?
  author_organization String?
  author_descriptor   String?
  posted_at           DateTime?
  posted_at_label     String
  body                String
  reaction_count      Int            @default(0)
  reply_count         Int            @default(0)
  sort_order          Int?
  source_url          String
  raw_payload         Json?
  synced_at           DateTime       @default(now())
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  @@unique([org_id, display_id])
  @@unique([link_id, source_message_id])
  @@index([org_id])
  @@index([patient_id, posted_at])
  @@index([source_message_id])
}

/// 患者項目の業務差分履歴(変更履歴 層b)+時点管理(層c)。
/// AuditLog(層a: DBトリガが行単位 before/after を自動記録)とは別レイヤで、
/// 現場が見る「項目単位の差分・確認元・適用開始日・更新者」を保持する。
/// ContactParty/Residence/PatientCondition は audit トリガ対象外のため、本表が唯一の変更履歴となる。
/// IncidentReport と同様に patient_id は FK を張らない緩い列とし、org_id + RLS でテナント分離する。
model PatientFieldRevision {
  id                     String    @id @default(cuid())
  org_id                 String
  display_id             String?
  patient_id             String
  case_id                String? // ケースに紐づく項目(intake/home_visit_intake)用
  category               String // 現状: basic/residence/contacts/conditions/clinical（pharmaceutical/medical_care/narcotic は後続スライスで追加）
  field_key              String // 現状: 基本情報/住所/contacts/conditions + 臨床(care_level/adl_level/dementia_level/swallowing_route/infection_isolation)。医療処置/麻薬は後続スライス
  field_label            String? // 表示名(例: 介護度)
  old_value              Json? // 変更前
  new_value              Json? // 変更後
  value_label            String? // 整形済み表示値(例: なし → あり)
  source                 String    @default("patient_detail_edit") // 確認元/由来: patient_detail_edit/visit_record/mcs_sync/import
  source_visit_record_id String? // 反映導線(訪問記録→患者詳細)で使用
  confirmed_by           String? // 確認者(別スタッフ) User ID
  confirmed_at           DateTime?
  valid_from             DateTime  @db.Date // 適用開始日
  valid_to               DateTime? @db.Date // 適用終了日(null=現在有効)
  is_current             Boolean   @default(true)
  change_reason          String? // 変更理由
  importance             String    @default("normal") // normal/caution/urgent
  updated_by             String // 入力者(actor) User ID
  created_at             DateTime  @default(now()) // 変更日時(システム入力日時)
  updated_at             DateTime  @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id, field_key, valid_from(sort: Desc)])
  @@index([patient_id, is_current])
  @@index([source_visit_record_id])
}

/// 在宅医療処置(TPN/CV/在宅酸素/経管/胃瘻/褥瘡/透析 等)の構造化保持。
/// 移行期は CareCase.required_visit_support.home_visit_intake.special_medical_procedures(JSON)が SoT で、
/// 本表は今後の書込を反映する追加レイヤ。各処置に開始日/終了日/確認元を持たせ算定・準備判断に使う。
/// IncidentReport 同様 patient_id は FK を張らず org_id + RLS でテナント分離する。
model PatientMedicalProcedure {
  id             String    @id @default(cuid())
  org_id         String
  display_id     String?
  patient_id     String
  case_id        String?
  procedure_type String // specialProcedureLabels のキー(tpn/cv/cv_port/picc/home_oxygen/enteral/gastrostomy/pressure_ulcer/dialysis ...)
  is_active      Boolean   @default(true)
  start_date     DateTime? @db.Date
  end_date       DateTime? @db.Date
  source         String    @default("patient_detail_edit") // 確認元/由来
  confirmed_by   String?
  confirmed_at   DateTime?
  notes          String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id, is_active])
  @@index([patient_id, procedure_type])
}

/// 在宅麻薬使用(ベース/レスキュー)の構造化保持。PatientMedicalProcedure と同方針(JSON継続SoT・追加レイヤ)。
model PatientNarcoticUse {
  id            String    @id @default(cuid())
  org_id        String
  display_id    String?
  patient_id    String
  case_id       String?
  narcotic_kind String // base / rescue
  is_active     Boolean   @default(true)
  start_date    DateTime? @db.Date
  end_date      DateTime? @db.Date
  source        String    @default("patient_detail_edit")
  confirmed_by  String?
  confirmed_at  DateTime?
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id, is_active])
}
