enum Gender {
  male
  female
  other
}

enum LabAnalyteCode {
  wbc
  neut
  hb
  plt
  pt_inr
  ast
  alt
  t_bil
  scr
  egfr
  ck
  crp
  k
  hba1c
  tp
  alb
  na
  cl
  bun
  bnp
  nt_pro_bnp
  blood_glucose
}

enum InsuranceType {
  medical
  care
  public_subsidy
}

enum InsuranceApplicationStatus {
  confirmed
  applying
  change_pending
  not_applicable
}

enum PackagingMethod {
  none
  unit_dose
  morning_evening_unit_dose
  medication_box
  calendar_pack
  blister_pack
  crush_and_pack
  other
}

enum CaseStatus {
  referral_received // 紹介受領
  assessment // アセスメント中
  active // 稼働中
  on_hold // 保留
  discharged // 退院/終了
  terminated // 解約
}

enum ConsentType {
  visit_medication_management // 訪問薬剤管理
  personal_info_handling // 個人情報取扱
  external_sharing // 外部共有
  photo_capture // 写真撮影
}

enum ConsentMethod {
  paper_scan // 紙署名スキャン
  digital // デジタル
}

enum ManagementPlanStatus {
  draft
  approved
  superseded
  archived
}

enum ContactRelation {
  self
  spouse
  child
  parent
  sibling
  care_manager
  physician
  nurse
  facility_staff
  other
}

enum PatientConditionType {
  disease
  problem
}

model Patient {
  id                       String    @id @default(cuid())
  org_id                   String
  display_id               String?
  name                     String
  name_kana                String
  birth_date               DateTime  @db.Date
  gender                   Gender
  phone                    String?
  medical_insurance_number String?
  care_insurance_number    String?
  billing_support_flag     Boolean   @default(false) // 請求支援フラグ
  allergy_info             Json? // アレルギー情報 (AllergyEntry[])
  notes                    String?
  // 担当チームは患者単位（原則）。user_id を保持し FK は張らず後段で名前解決/組織検証する（CareCase の担当列と同方針）。
  primary_pharmacist_id    String? // 主担当薬剤師 (user_id)
  backup_pharmacist_id     String? // 副担当薬剤師 (user_id)
  primary_staff_id         String? // 主担当スタッフ (事務等, user_id)
  backup_staff_id          String? // 副担当スタッフ (user_id)
  archived_at              DateTime?
  archived_by              String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  residences                 Residence[]
  cases                      CareCase[]
  contacts                   ContactParty[]
  conditions                 PatientCondition[]
  consents                   ConsentRecord[]
  scheduling_preference      PatientSchedulePreference?
  medication_profiles        MedicationProfile[]
  packaging_profile          PatientPackagingProfile?
  mcs_link                   PatientMcsLink?
  mcs_summary                PatientMcsSummary?
  mcs_messages               PatientMcsMessage[]
  insurances                 PatientInsurance[]
  lab_observations           PatientLabObservation[]
  jahis_supplemental_records JahisSupplementalRecord[]
  workflow_exceptions        WorkflowException[]
  share_cases_as_base        PatientShareCase[]         @relation("PatientShareCaseBasePatient")

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@index([org_id])
  @@index([name_kana])
}

model Residence {
  id               String        @id @default(cuid())
  org_id           String
  display_id       String?
  patient_id       String
  patient          Patient       @relation(fields: [patient_id], references: [id])
  address          String
  building_id      String? // レガシー: 自由テキスト (後方互換)
  facility_id      String? // FK: Facility マスターへのリンク
  facility         Facility?     @relation(fields: [facility_id], references: [id])
  facility_unit_id String? // FK: FacilityUnit (フロア/ユニット)
  facility_unit    FacilityUnit? @relation(fields: [facility_unit_id], references: [id])
  unit_name        String? // 部屋番号等 (e.g., "203号室")
  lat              Float?
  lng              Float?
  geocode_status   String?
  geocode_source   String?
  geocode_accuracy String?
  geocoded_at      DateTime?
  is_primary       Boolean       @default(true)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([facility_id])
  @@index([facility_unit_id])
}

model CareCase {
  id                     String     @id @default(cuid())
  org_id                 String
  display_id             String?
  patient_id             String
  patient                Patient    @relation(fields: [patient_id], references: [id])
  status                 CaseStatus @default(referral_received)
  referral_source        String? // 紹介元
  referral_date          DateTime?
  start_date             DateTime?
  end_date               DateTime?
  end_reason             String?
  primary_pharmacist_id  String?
  backup_pharmacist_id   String?
  primary_staff_id       String?
  backup_staff_id        String?
  required_visit_support Json?
  notes                  String?
  created_at             DateTime   @default(now())
  updated_at             DateTime   @updatedAt

  care_team_links          CareTeamLink[]
  management_plans         ManagementPlan[]
  medication_cycles        MedicationCycle[]
  visit_schedules          VisitSchedule[]
  visit_schedule_proposals VisitScheduleProposal[]
  care_reports             CareReport[]
  patient_share_cases      PatientShareCase[]      @relation("PatientShareCaseBaseCareCase")

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([status])
}

model ContactParty {
  id                   String          @id @default(cuid())
  org_id               String
  display_id           String?
  patient_id           String
  patient              Patient         @relation(fields: [patient_id], references: [id])
  name                 String
  relation             ContactRelation
  phone                String?
  email                String?
  fax                  String?
  organization_name    String? // 所属組織名
  department           String?
  address              String?
  is_primary           Boolean         @default(false)
  is_emergency_contact Boolean         @default(false)
  notes                String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
}

model CareTeamLink {
  id                       String                @id @default(cuid())
  org_id                   String
  display_id               String?
  case_id                  String
  case_                    CareCase              @relation(fields: [case_id], references: [id])
  external_professional_id String?
  external_professional    ExternalProfessional? @relation(fields: [external_professional_id], references: [id], onDelete: SetNull)
  role                     String // physician/nurse/care_manager/pharmacist/other
  name                     String
  organization_name        String?
  department               String?
  phone                    String?
  email                    String?
  fax                      String?
  address                  String?
  is_primary               Boolean               @default(false)
  notes                    String?
  created_at               DateTime              @default(now())
  updated_at               DateTime              @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([case_id])
  @@index([external_professional_id])
}

model PatientCondition {
  id             String               @id @default(cuid())
  org_id         String
  display_id     String?
  patient_id     String
  patient        Patient              @relation(fields: [patient_id], references: [id])
  condition_type PatientConditionType
  name           String
  is_primary     Boolean              @default(false)
  is_active      Boolean              @default(true)
  noted_at       DateTime?            @db.Date
  notes          String?
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([condition_type])
}

model ConsentRecord {
  id                String        @id @default(cuid())
  org_id            String
  display_id        String?
  patient_id        String
  patient           Patient       @relation(fields: [patient_id], references: [id])
  case_id           String?
  template_id       String?
  template          Template?     @relation(fields: [template_id], references: [id])
  template_version  Int?
  consent_type      ConsentType
  method            ConsentMethod
  obtained_date     DateTime
  expiry_date       DateTime?
  revoked_date      DateTime?
  document_url      String? // S3のスキャン文書URL
  document_file_id  String?
  document_file     FileAsset?    @relation(fields: [document_file_id], references: [id])
  is_active         Boolean       @default(true)
  access_restricted Boolean       @default(false) // 撤回後の閲覧制限フラグ
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  patient_share_consents PatientShareConsent[]

  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([org_id, document_file_id])
}

model ManagementPlan {
  id               String               @id @default(cuid())
  org_id           String
  display_id       String?
  case_id          String
  case_            CareCase             @relation(fields: [case_id], references: [id])
  status           ManagementPlanStatus @default(draft)
  version          Int                  @default(1)
  title            String               @default("訪問薬剤管理指導計画書")
  summary          String?
  content          Json // 計画書内容
  created_by       String // User ID
  approved_by      String?
  approved_at      DateTime?
  reviewed_by      String?
  reviewed_at      DateTime?
  effective_from   DateTime?            @db.Date
  next_review_date DateTime?
  source_plan_id   String?
  created_at       DateTime             @default(now())
  updated_at       DateTime             @updatedAt

  @@unique([org_id, display_id])
  @@unique([case_id, version])
  @@index([org_id])
  @@index([case_id])
  @@index([status])
}

model PatientSchedulePreference {
  id                            String    @id @default(cuid())
  org_id                        String
  display_id                    String?
  patient_id                    String    @unique
  patient                       Patient   @relation(fields: [patient_id], references: [id])
  preferred_weekdays            Json?
  preferred_time_from           DateTime? @db.Time()
  preferred_time_to             DateTime? @db.Time()
  phone_contact_from            DateTime? @db.Time()
  phone_contact_to              DateTime? @db.Time()
  facility_time_from            DateTime? @db.Time()
  facility_time_to              DateTime? @db.Time()
  family_presence_required      Boolean   @default(false)
  visit_buffer_minutes          Int?
  preferred_contact_name        String?
  preferred_contact_phone       String?
  notes                         String?
  // HVI-01B: structured scheduling & onboarding fields
  visit_before_contact_required Boolean?
  first_visit_preferred_date    DateTime? @db.Date
  first_visit_time_slot         String?
  first_visit_time_note         String?
  parking_available             Boolean?
  primary_contact_preference    String?
  mcs_linked                    Boolean?
  // P-09: structured intake columns
  adl_level                     String?
  dementia_level                String?
  swallowing_route              String?
  care_level                    String?
  infection_isolation           Boolean   @default(false)
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
}

// MedicationProfile は medication.prisma で定義予定（未実装時はコメントアウト）
// model MedicationProfile は他ファイルで定義

model PatientPackagingProfile {
  id                       String           @id @default(cuid())
  org_id                   String
  display_id               String?
  patient_id               String           @unique
  patient                  Patient          @relation(fields: [patient_id], references: [id])
  default_packaging_method PackagingMethod?
  medication_box_color     String?
  notes                    String?
  box_config               Json? // 配薬BOX設定 (例: 仕切り数、ラベル色など)
  special_instructions     String? // 個別特記指示
  cognitive_note           String? // 認知機能・服薬自己管理に関する注記
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
}

model PatientMcsLink {
  id                   String    @id @default(cuid())
  org_id               String
  display_id           String?
  patient_id           String    @unique
  patient              Patient   @relation(fields: [patient_id], references: [id])
  source_url           String
  mcs_patient_id       String?
  mcs_patient_url      String?
  mcs_project_id       String?
  mcs_project_url      String?
  project_title        String?
  project_memo         String?
  member_count         Int?
  last_sync_attempt_at DateTime?
  last_synced_at       DateTime?
  last_sync_status     String?
  last_sync_error      String?
  created_by           String?
  updated_by           String?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  messages PatientMcsMessage[]
  summary  PatientMcsSummary?

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([mcs_project_id])
}

model PatientMcsSummary {
  id                               String         @id @default(cuid())
  org_id                           String
  display_id                       String?
  patient_id                       String         @unique
  patient                          Patient        @relation(fields: [patient_id], references: [id])
  link_id                          String         @unique
  link                             PatientMcsLink @relation(fields: [link_id], references: [id], onDelete: Cascade)
  generation_id                    String
  provider                         String
  requested_provider               String
  is_fallback                      Boolean        @default(false)
  model                            String?
  fallback_reason                  String?
  headline                         String
  bullets                          String[]       @default([])
  must_check_today                 String[]       @default([])
  suggested_actions                String[]       @default([])
  source_refs                      String[]       @default([])
  message_count                    Int            @default(0)
  other_professional_message_count Int            @default(0)
  latest_posted_at                 DateTime?
  generated_at                     DateTime
  duration_ms                      Int?
  created_at                       DateTime       @default(now())
  updated_at                       DateTime       @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([link_id])
