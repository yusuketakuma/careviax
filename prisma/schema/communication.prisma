enum CommunicationChannel {
  ph_os_share // PH-OS 内共有（アプリ内連携。送付方法の既定・推奨）
  email
  fax
  phone
  in_person
  postal
  ses
}

enum ReportStatus {
  draft
  sent
  failed
  confirmed
  response_waiting
}

enum ReportType {
  physician_report
  care_manager_report
  facility_handoff
  nurse_share
  family_share
  internal_record
}

enum RequestStatus {
  draft
  sent
  received
  in_progress
  responded
  closed
  escalated
  cancelled
  expired
}

enum TracingReportStatus {
  draft
  sent
  received
  acknowledged
}

enum SelfReportStatus {
  submitted
  triaged
  converted_to_task
  resolved
  dismissed
}

model CommunicationEvent {
  id                  String               @id @default(cuid())
  org_id              String
  display_id          String?
  patient_id          String?
  case_id             String?
  event_type          String // schedule_change/physician_report/care_manager_report/tracing_report/delivery_failure/resend
  channel             CommunicationChannel
  direction           String // outbound/inbound
  counterpart_name    String?
  counterpart_contact String?
  subject             String?
  content             String?
  attachments         Json?
  occurred_at         DateTime             @default(now())
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([event_type])
}

model CommunicationRequest {
  id                  String        @id @default(cuid())
  org_id              String
  display_id          String?
  patient_id          String?
  case_id             String?
  request_type        String
  template_key        String?
  recipient_name      String?
  recipient_role      String?
  related_entity_type String?
  related_entity_id   String?
  context_snapshot    Json?
  status              RequestStatus @default(draft)
  subject             String
  content             String
  requested_by        String // User ID
  requested_at        DateTime      @default(now())
  due_date            DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  responses CommunicationResponse[]

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([status])
  @@index([related_entity_type, related_entity_id])
}

model CommunicationResponse {
  id                  String               @id @default(cuid())
  org_id              String
  display_id          String?
  request_id          String
  request             CommunicationRequest @relation(fields: [request_id], references: [id])
  responder_name      String
  content             String
  responded_at        DateTime
  response_intent_key String?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  @@unique([org_id, display_id])
  @@unique([org_id, response_intent_key])
  @@index([org_id])
  @@index([request_id])
}

model CareReport {
  id                      String              @id @default(cuid())
  org_id                  String
  display_id              String?
  visit_record_id         String?
  partner_visit_record_id String?
  partner_visit_record    PartnerVisitRecord? @relation("CareReportPartnerVisitRecord", fields: [partner_visit_record_id, org_id], references: [id, org_id])
  patient_id              String
  case_id                 String?
  case_                   CareCase?           @relation(fields: [case_id], references: [id])
  report_type             ReportType
  status                  ReportStatus        @default(draft)
  content                 Json
  template_id             String?
  pdf_url                 String? // S3
  created_by              String // User ID
  created_at              DateTime            @default(now())
  updated_at              DateTime            @updatedAt

  delivery_records DeliveryRecord[]
  send_requests    CareReportSendRequest[]

  // DB contract: migration 20260512021000_add_care_report_visit_type_unique_index
  // creates the partial unique index
  // CareReport_org_visit_record_report_type_unique_idx on
  // (org_id, visit_record_id, report_type) for non-null visit_record_id
  // so one visit cannot produce duplicate report drafts for the same report_type.
  // Partner-visit source reports are similarly guarded by
  // CareReport_org_partner_visit_report_type_key.
  @@unique([org_id, display_id])
  @@unique([id, org_id])
  @@unique([org_id, partner_visit_record_id, report_type], map: "CareReport_org_partner_visit_report_type_key")
  @@index([org_id])
  @@index([patient_id])
  @@index([status])
  @@index([case_id])
  @@index([org_id, partner_visit_record_id])
}

model CareReportSendRequest {
  id                   String     @id @default(cuid())
  org_id               String
  display_id           String?
  report_id            String
  report               CareReport @relation(fields: [report_id, org_id], references: [id, org_id])
  idempotency_key_hash String
  request_fingerprint  String
  claim_token          String
  status               String     @default("in_progress")
  response_status      Int?
  response_body        Json?
  completed_at         DateTime?
  created_by           String
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  @@unique([org_id, display_id])
  @@unique([org_id, report_id, idempotency_key_hash], name: "org_report_send_request_idempotency_key", map: "CareReportSendRequest_org_report_idem_key")
  @@index([org_id])
  @@index([org_id, report_id], map: "CareReportSendRequest_org_id_report_id_idx")
  @@index([status])
}

model DeliveryRecord {
  id                  String               @id @default(cuid())
  org_id              String
  display_id          String?
  report_id           String
  report              CareReport           @relation(fields: [report_id], references: [id])
  channel             CommunicationChannel
  recipient_name      String
  recipient_contact   String
  delivery_intent_key String?
  status              ReportStatus         @default(draft)
  sent_at             DateTime?
  confirmed_at        DateTime?
  failure_reason      String?
  retry_count         Int                  @default(0)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt

  @@unique([org_id, display_id])
  @@unique([org_id, delivery_intent_key])
  @@index([org_id])
  @@index([status])
}

enum ConferenceNoteType {
  regular
  pre_discharge
  service_manager
  care_team
  emergency
  death_conference
}

model ConferenceNote {
  id                  String             @id @default(cuid())
  org_id              String
  display_id          String?
  case_id             String?
  patient_id          String?
  facility_id         String?
  note_type           ConferenceNoteType @default(regular)
  title               String
  content             String
  structured_content  Json?
  metadata            Json?
  billing_eligible    Boolean            @default(false)
  billing_code        String?
  follow_up_date      DateTime?
  follow_up_completed Boolean            @default(false)
  generated_report_id String?
  participants        Json // [{name, role}]
  conference_date     DateTime
  action_items        Json? // Task 変換用
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([case_id])
  @@index([patient_id])
  @@index([facility_id])
  @@index([note_type])
  @@index([follow_up_date])
}

model EscalationRule {
  id           String   @id @default(cuid())
  org_id       String
  display_id   String?
  trigger_type String
  condition    Json
  action       String
  notify_role  String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
}

model ExternalAccessGrant {
  id                 String    @id @default(cuid())
  org_id             String
  display_id         String?
  patient_id         String
  token_hash         String    @unique
  expires_at         DateTime
  otp_hash           String?
  granted_to_name    String
  granted_to_contact String?
  scope              Json // アクセス可能な情報の範囲
  accessed_at        DateTime?
  revoked_at         DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([token_hash])
}

model TracingReport {
  id                String              @id @default(cuid())
  org_id            String
  display_id        String?
  patient_id        String
  case_id           String?
  issue_id          String?
  issue             MedicationIssue?    @relation(fields: [issue_id], references: [id])
  content           Json
  status            TracingReportStatus @default(draft)
  sent_to_physician String?
  sent_at           DateTime?
  acknowledged_at   DateTime?
  pdf_url           String?
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([patient_id])
  @@index([status])
}

model PatientSelfReport {
  id                       String           @id @default(cuid())
  org_id                   String
  display_id               String?
  patient_id               String
  external_access_grant_id String?
  reported_by_name         String
  relation                 String?
  category                 String
  subject                  String
  content                  String
  requested_callback       Boolean          @default(false)
  preferred_contact_time   String?
  idempotency_key_hash     String?
  request_fingerprint      String?
  status                   SelfReportStatus @default(submitted)
  triaged_by               String?
  triaged_at               DateTime?
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  @@unique([org_id, display_id])
  @@unique([org_id, external_access_grant_id, idempotency_key_hash], name: "org_grant_idempotency_key", map: "PatientSelfReport_org_grant_idem_key")
  @@index([org_id])
  @@index([org_id, external_access_grant_id], map: "PatientSelfReport_org_id_external_access_grant_id_idx")
  @@index([patient_id])
  @@index([status])
}

model CommunityActivity {
  id                  String   @id @default(cuid())
  org_id              String
  display_id          String?
  activity_type       String
  title               String
  description         String?
  partner_name        String?
  activity_date       DateTime
  target_population   String?
  attendee_count      Int?
  referrals_generated Int?
  follow_up_required  Boolean  @default(false)
  outcome_summary     String?
  created_by          String
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([activity_type])
  @@index([activity_date])
}

// ── 薬局内コミュニケーション ──────────────────────────

model TaskComment {
  id          String   @id @default(cuid())
  org_id      String
  display_id  String?
  entity_type String // medication_cycle, dispense_task, set_plan, visit_record, care_report
  entity_id   String
  author_id   String
  content     String
  mentions    String[] // user IDs mentioned via @
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([org_id, display_id])
  @@index([org_id])
  @@index([entity_type, entity_id])
  @@index([author_id])
}

model HandoffBoard {
  id         String        @id @default(cuid())
  org_id     String
  display_id String?
  shift_date DateTime      @db.Date
  created_by String
  items      HandoffItem[]
  created_at DateTime      @default(now())

  @@unique([org_id, display_id])
  @@unique([org_id, shift_date])
  @@index([org_id])
}

model HandoffItem {
  id                String       @id @default(cuid())
  board_id          String
  display_id        String?
  board             HandoffBoard @relation(fields: [board_id], references: [id])
  content           String
  priority          String       @default("normal") // normal, high, urgent
  entity_type       String? // optional link to workflow entity
  entity_id         String?
  read_by           String[] // user IDs who confirmed reading
  // --- responsibility transfer model (new design 12_handoff) ---
  // All nullable for backward compatibility: legacy rows (= plain shift notes)
  // keep every new column NULL and continue to work with the read_by flow.
  recipient_user_id String? // who the work is handed to (User ID)
  recipient_label   String? // display label e.g. 「佐藤さん」「鈴木さん(事務)」「事務」
  lifecycle_status  String? // proposed / in_progress / confirming / completed
  scope             String? // ①何を(作業の範囲)
  rationale         String? // ②なぜ(根拠)
  deadline          DateTime? // ③いつまで(期限)
  progress_done     Int? // 作業中 9/12 の 9
  progress_total    Int? // 作業中 9/12 の 12
  // --- 薬剤師に相談 / 事務へ戻す 相談解決フロー (p0_27) ---
  // 全 nullable。consult_status が NULL の行は従来の引き継ぎ/作業移譲アイテム。
  consult_status    String? // 相談の状態: open / checking / returned_to_clerk / resolved
  resolution_action String? // 薬剤師の対応: acknowledged / escalated_to_physician / returned_to_clerk
  resolution_note   String? // 対応メモ（事務へ戻す際の指示等）
  resolved_by       String? // 対応した User ID
  resolved_at       DateTime?
  created_by        String
  created_at        DateTime     @default(now())

  @@index([board_id])
  @@index([display_id])
  @@index([recipient_user_id])
  @@index([consult_status])
}
