# =============================================================================
# PH-OS Environment Variables
# Copy this file to .env.local for local development.
# All variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] have sensible defaults.
# =============================================================================

# ─────────────────────────────────────────────────────────────
# Deployment environment
# Values: development | staging | production
# ─────────────────────────────────────────────────────────────
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# ─────────────────────────────────────────────────────────────
# AWS (all services are in ap-northeast-1 / Tokyo)
# ─────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-1          # [REQUIRED]
AWS_ACCESS_KEY_ID=                  # [OPTIONAL] prefer runtime IAM role / container credentials in production
AWS_SECRET_ACCESS_KEY=              # [OPTIONAL] prefer runtime IAM role / container credentials in production

# ─────────────────────────────────────────────────────────────
# Database (Amazon RDS PostgreSQL — Multi-AZ, encrypted)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@rds-endpoint:5432/ph_os   # [REQUIRED]
DIRECT_URL=postgresql://user:pass@rds-endpoint:5432/ph_os     # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# Amazon Cognito
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx   # [REQUIRED]
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx  # [REQUIRED]
COGNITO_CLIENT_SECRET=                                       # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# NextAuth / Auth.js
# ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000   # [REQUIRED]
NEXTAUTH_SECRET=                     # [REQUIRED] openssl rand -hex 32
TRUST_PROXY_HEADERS=false            # [REQUIRED in production] set true only behind a trusted reverse proxy / load balancer
TRUSTED_PROXY_HOPS=0                 # [OPTIONAL] number of trusted rightmost X-Forwarded-For hops

# ─────────────────────────────────────────────────────────────
# API rate limiting
# Production fails closed unless the distributed store is configured.
# The DynamoDB table must use pk (string) as the partition key and TTL on expires_at.
# See tools/infra/rate-limit-dynamodb.json for the table and least-privilege IAM contract.
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_STORE=dynamodb            # [REQUIRED in production] values: dynamodb
RATE_LIMIT_DDB_TABLE_NAME=ph-os-rate-limit  # [REQUIRED in production]
RATE_LIMIT_DDB_REGION=ap-northeast-1 # [OPTIONAL] defaults to AWS_REGION
RATE_LIMIT_DDB_TIMEOUT_MS=1500       # [OPTIONAL] fail-closed timeout for proxy checks
# Static AWS keys are not required for rate limiting when the runtime exposes AWS_CONTAINER_CREDENTIALS_RELATIVE_URI,
# AWS_CONTAINER_CREDENTIALS_FULL_URI (localhost/127.0.0.1/169.254.170.2 only), or AWS_ECS_CONTAINER_CREDENTIALS_RELATIVE_URI.

# ─────────────────────────────────────────────────────────────
# Amazon S3
# ─────────────────────────────────────────────────────────────
S3_BUCKET_NAME=ph-os-files-prod   # [REQUIRED]
S3_BUCKET_REGION=ap-northeast-1      # [OPTIONAL]

# ─────────────────────────────────────────────────────────────
# Amazon SES
# ─────────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@example.com   # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # [REQUIRED]

# AES-GCM 256-bit key for IndexedDB PHI encryption (base64-encoded 32 bytes)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=                            # [REQUIRED]

# HMAC secret for external share tokens
# Generate: openssl rand -hex 32
JWT_SIGNING_SECRET=                        # [REQUIRED]

# ─────────────────────────────────────────────────────────────
# Sentry — error tracking & performance monitoring
# Leave blank in development to disable.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=    # [OPTIONAL] from sentry.io project settings
SENTRY_DSN=                # [OPTIONAL] same value as NEXT_PUBLIC_SENTRY_DSN
SENTRY_ORG=                # [OPTIONAL] Sentry organization slug
SENTRY_PROJECT=            # [OPTIONAL] Sentry project slug
SENTRY_AUTH_TOKEN=         # [OPTIONAL] required for source map uploads in CI

# ─────────────────────────────────────────────────────────────
# AWS Amplify (auto-injected at build time — do not set manually)
# ─────────────────────────────────────────────────────────────
# AWS_APP_ID=
# AWS_BRANCH=
# AWS_COMMIT_ID=
