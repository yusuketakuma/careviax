{
  "trailName": "ph-os-org-trail",
  "isMultiRegionTrail": true,
  "includeGlobalServiceEvents": true,
  "enableLogFileValidation": true,
  "s3BucketName": "ph-os-cloudtrail-logs",
  "s3KeyPrefix": "cloudtrail/",
  "kmsKeyAlias": "alias/ph-os-cloudtrail",
  "eventSelectors": [
    {
      "readWriteType": "All",
      "includeManagementEvents": true,
      "dataResources": [
        {
          "type": "AWS::S3::Object",
          "values": [
            "arn:aws:s3:::ph-os-main-bucket/reports/",
            "arn:aws:s3:::ph-os-main-bucket/prescriptions/",
            "arn:aws:s3:::ph-os-audit-archive/audit-logs/"
          ]
        }
      ]
    }
  ],
  "cloudWatchLogs": {
    "enabled": true,
    "logGroupName": "/ph-os/cloudtrail",
    "retentionInDays": 365
  }
}
