# PH-OS Lightsail runtime environment example.
# Copy to an untracked file, replace every placeholder, and upload with:
#   pnpm aws:lightsail:runtime:plan -- --host <STATIC_IP_OR_DOMAIN> --image <IMAGE> --env-file <UNTRACKED_ENV_FILE>

APP_ENV=production
NEXT_PUBLIC_APP_ENV=production
AWS_REGION=ap-northeast-1
PORT=3000
HOSTNAME=0.0.0.0

DATABASE_URL=postgresql://phosadmin:<PASSWORD>@<DB_ENDPOINT>:5432/ph_os?sslmode=require
DIRECT_URL=postgresql://phosadmin:<PASSWORD>@<DB_ENDPOINT>:5432/ph_os?sslmode=require

NEXTAUTH_URL=https://<DOMAIN>
NEXT_PUBLIC_APP_URL=https://<DOMAIN>
NEXTAUTH_SECRET=<GENERATED_SECRET>
ENCRYPTION_KEY=<GENERATED_BASE64_32_BYTES>
JWT_SIGNING_SECRET=<GENERATED_HEX_SECRET>

NEXT_PUBLIC_COGNITO_USER_POOL_ID=<COGNITO_POOL_ID>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<COGNITO_CLIENT_ID>
COGNITO_CLIENT_SECRET=<COGNITO_CLIENT_SECRET>

S3_BUCKET_NAME=<S3_BUCKET>
S3_BUCKET_REGION=ap-northeast-1
SES_FROM_EMAIL=<SES_FROM_EMAIL>

TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_HOPS=0
PHOS_DISABLE_LEGACY_FILE_API=1
RATE_LIMIT_STORE=dynamodb
RATE_LIMIT_DDB_TABLE_NAME=ph-os-rate-limit
RATE_LIMIT_DDB_REGION=ap-northeast-1
RATE_LIMIT_DDB_TIMEOUT_MS=1500

SECRETS_MANAGER_ENABLED=
SECRETS_MANAGER_SECRET_ID=
SECRETS_MANAGER_DISABLED=
