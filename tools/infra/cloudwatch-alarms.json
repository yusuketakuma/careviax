{
  "description": "CloudWatch alarms for PH-OS production baseline.",
  "alarms": [
    {
      "name": "ph-os-api-health-down",
      "metric": "HealthStatusDown",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Maximum",
      "dimensions": {
        "route": "/api/health"
      },
      "alarmDescription": "Triggered when /api/health returns down."
    },
    {
      "name": "ph-os-api-5xx-rate",
      "metric": "5XXError",
      "namespace": "AWS/ApplicationELB",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 5,
      "evaluationPeriods": 3,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "Triggered when ALB returns repeated 5xx responses."
    },
    {
      "name": "ph-os-route-p99-latency-high",
      "metric": "OverallP99LatencyMs",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 1000,
      "evaluationPeriods": 3,
      "datapointsToAlarm": 2,
      "periodSeconds": 300,
      "statistic": "Maximum",
      "dimensions": {
        "OrgScope": "aggregate"
      },
      "alarmDescription": "Application route p99 latency exceeded the production tail-latency baseline."
    },
    {
      "name": "ph-os-payload-budget-over-routes",
      "metric": "PayloadBudgetOverRoutes",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 0,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Maximum",
      "dimensions": {
        "OrgScope": "aggregate"
      },
      "alarmDescription": "One or more critical application routes exceeded the payload budget."
    },
    {
      "name": "ph-os-action-latency-high",
      "metric": "ActionLatencyMs",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 5000,
      "evaluationPeriods": 3,
      "periodSeconds": 60,
      "statistic": "Average",
      "alarmDescription": "PH-OS backend action latency exceeded the P0 baseline."
    },
    {
      "name": "ph-os-action-guard-failed",
      "metric": "ActionGuardFailedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS action guard failures occurred."
    },
    {
      "name": "ph-os-tenant-boundary-rejected",
      "metric": "TenantBoundaryRejectedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS rejected tenant_id in external request input."
    },
    {
      "name": "ph-os-cross-tenant-attempt",
      "metric": "CrossTenantAttemptCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS detected a cross-tenant access attempt."
    },
    {
      "name": "ph-os-visit-complete-guard-blocked",
      "metric": "VisitCompleteGuardBlockedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS blocked visit completion because required guard conditions were not met."
    },
    {
      "name": "ph-os-evidence-upload-failed",
      "metric": "EvidenceUploadFailedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS evidence upload verification or persistence failed."
    },
    {
      "name": "ph-os-offline-sync-conflict",
      "metric": "OfflineSyncConflictCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS offline sync conflict occurred."
    },
    {
      "name": "ph-os-handoff-returned",
      "metric": "HandoffReturnedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS pharmacist handoff was returned to the clerk queue."
    },
    {
      "name": "ph-os-report-send-failed",
      "metric": "ReportSendFailedCount",
      "namespace": "PHOS/Backend",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "PH-OS report send failed."
    },
    {
      "name": "ph-os-rate-limit-unavailable",
      "metric": "RateLimitUnavailable",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "A production API request failed closed because the distributed rate-limit backend was unavailable or misconfigured."
    },
    {
      "name": "ph-os-rds-cpu-high",
      "metric": "CPUUtilization",
      "namespace": "AWS/RDS",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 80,
      "evaluationPeriods": 3,
      "periodSeconds": 300,
      "statistic": "Average",
      "alarmDescription": "RDS CPU has been above 80 percent for 15 minutes."
    },
    {
      "name": "ph-os-rds-free-storage-low",
      "metric": "FreeStorageSpace",
      "namespace": "AWS/RDS",
      "comparisonOperator": "LessThanThreshold",
      "threshold": 10737418240,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Average",
      "alarmDescription": "RDS free storage under 10 GiB."
    },
    {
      "name": "ph-os-audit-archive-lifecycle-warning",
      "metric": "BackupMonitorWarning",
      "namespace": "PH-OS/Operations",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Maximum",
      "dimensions": {
        "check": "auditArchive"
      },
      "alarmDescription": "Audit archive lifecycle policy is missing or misconfigured."
    },
    {
      "name": "ph-os-job-execution-failed",
      "metric": "JobExecutionFailedCount",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Sum",
      "alarmDescription": "A background job exhausted all retries and failed permanently. Derived from the job.execution_failed structured log via the CloudWatch Logs metric filter below (declaration only; apply as an operational step).",
      "metricFilter": {
        "logGroupName": "/ph-os/application",
        "filterName": "ph-os-job-execution-failed",
        "filterPattern": "{ $.event = \"job.execution_failed\" }",
        "metricNamespace": "PH-OS/Application",
        "metricName": "JobExecutionFailedCount",
        "metricValue": "1",
        "defaultValue": 0
      }
    }
  ]
}
