{
  "description": "CloudWatch alarms for PH-OS production baseline.",
  "alarms": [
    {
      "name": "ph-os-api-health-down",
      "metric": "HealthStatusDown",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Maximum",
      "dimensions": {
        "route": "/api/health"
      },
      "alarmDescription": "Triggered when /api/health returns down."
    },
    {
      "name": "ph-os-api-5xx-rate",
      "metric": "5XXError",
      "namespace": "AWS/ApplicationELB",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 5,
      "evaluationPeriods": 3,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "Triggered when ALB returns repeated 5xx responses."
    },
    {
      "name": "ph-os-rate-limit-unavailable",
      "metric": "RateLimitUnavailable",
      "namespace": "PH-OS/Application",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 60,
      "statistic": "Sum",
      "alarmDescription": "A production API request failed closed because the distributed rate-limit backend was unavailable or misconfigured."
    },
    {
      "name": "ph-os-rds-cpu-high",
      "metric": "CPUUtilization",
      "namespace": "AWS/RDS",
      "comparisonOperator": "GreaterThanThreshold",
      "threshold": 80,
      "evaluationPeriods": 3,
      "periodSeconds": 300,
      "statistic": "Average",
      "alarmDescription": "RDS CPU has been above 80 percent for 15 minutes."
    },
    {
      "name": "ph-os-rds-free-storage-low",
      "metric": "FreeStorageSpace",
      "namespace": "AWS/RDS",
      "comparisonOperator": "LessThanThreshold",
      "threshold": 10737418240,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Average",
      "alarmDescription": "RDS free storage under 10 GiB."
    },
    {
      "name": "ph-os-audit-archive-lifecycle-warning",
      "metric": "BackupMonitorWarning",
      "namespace": "PH-OS/Operations",
      "comparisonOperator": "GreaterThanOrEqualToThreshold",
      "threshold": 1,
      "evaluationPeriods": 1,
      "periodSeconds": 300,
      "statistic": "Maximum",
      "dimensions": {
        "check": "auditArchive"
      },
      "alarmDescription": "Audit archive lifecycle policy is missing or misconfigured."
    }
  ]
}
