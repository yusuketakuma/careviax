#!/usr/bin/env bash
# Lightweight opt-in pre-commit hook.
#
# Scope: staged files only (never the whole repo). Runs:
#   - Gitleaks 8.30.1 against the staged snapshot
#   - `pnpm exec eslint --max-warnings=0` on staged .ts/.tsx/.mjs files
#   - `pnpm exec prettier --check` on staged files with a Prettier-covered extension
#
# Does NOT run typecheck/build (too slow for a commit-time hook; those run in CI /
# the agent-loop gate instead).
#
# Opt-in: enable with `pnpm hooks:install` (sets `core.hooksPath` to this directory).
# Bypass a single commit with `SKIP_HOOKS=1 git commit ...`.
#
# NOTE: this script targets bash 3.2 (macOS system default) — no `mapfile`, no
# bash4-only builtins.
set -euo pipefail

if [ "${SKIP_HOOKS:-}" = "1" ]; then
  echo "[pre-commit] SKIP_HOOKS=1 -> skipping lint/format checks"
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files=()
while IFS= read -r line; do
  [ -n "$line" ] && staged_files+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "${#staged_files[@]}" -eq 0 ]; then
  exit 0
fi

lint_files=()
format_files=()

for f in "${staged_files[@]}"; do
  # Skip files that were staged then deleted from the working tree before commit.
  [ -f "$f" ] || continue

  case "$f" in
    *.ts | *.tsx | *.mjs)
      lint_files+=("$f")
      ;;
  esac

  case "$f" in
    pnpm-lock.yaml)
      ;;
    *.js | *.jsx | *.ts | *.tsx | *.mjs | *.cjs | *.json | *.md | *.yml | *.yaml | *.css)
      format_files+=("$f")
      ;;
  esac
done

status=0

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-commit] gitleaks 8.30.1 is required. Run tools/scripts/install-gitleaks.sh and add the printed bin directory to PATH."
  status=1
elif ! gitleaks_version="$(gitleaks version 2>/dev/null)" || [ "$gitleaks_version" != "8.30.1" ]; then
  echo "[pre-commit] gitleaks 8.30.1 is required; another version is installed."
  status=1
else
  echo "[pre-commit] gitleaks staged secret scan"
  gitleaks_log="$(mktemp)"
  trap 'rm -f "$gitleaks_log"' EXIT
  if ! gitleaks git --pre-commit --redact=100 --staged --verbose >"$gitleaks_log" 2>&1; then
    echo "[pre-commit] secret scan failed or detected a staged secret. Review locally with redaction enabled."
    status=1
  fi
  rm -f "$gitleaks_log"
fi

if [ "${#lint_files[@]}" -gt 0 ]; then
  echo "[pre-commit] eslint --max-warnings=0 (${#lint_files[@]} file(s))"
  if ! pnpm exec eslint --max-warnings=0 "${lint_files[@]}"; then
    status=1
  fi
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  echo "[pre-commit] prettier --check (${#format_files[@]} file(s))"
  if ! pnpm exec prettier --check "${format_files[@]}"; then
    status=1
  fi
fi

if [ "$status" -ne 0 ]; then
  echo ""
  echo "[pre-commit] security/lint/format check failed. Fix the issues above. Exceptional audited bypass:"
  echo "  SKIP_HOOKS=1 git commit ..."
fi

exit "$status"
