{
  "trailName": "careviax-org-trail",
  "isMultiRegionTrail": true,
  "includeGlobalServiceEvents": true,
  "enableLogFileValidation": true,
  "s3BucketName": "careviax-cloudtrail-logs",
  "s3KeyPrefix": "cloudtrail/",
  "kmsKeyAlias": "alias/careviax-cloudtrail",
  "eventSelectors": [
    {
      "readWriteType": "All",
      "includeManagementEvents": true,
      "dataResources": [
        {
          "type": "AWS::S3::Object",
          "values": [
            "arn:aws:s3:::careviax-main-bucket/reports/",
            "arn:aws:s3:::careviax-main-bucket/prescriptions/",
            "arn:aws:s3:::careviax-audit-archive/audit-logs/"
          ]
        }
      ]
    }
  ],
  "cloudWatchLogs": {
    "enabled": true,
    "logGroupName": "/careviax/cloudtrail",
    "retentionInDays": 365
  }
}
